                    $results+=[PSCustomObject]@{Tipo="CRASH_CHEAT";Nombre=$cr.Name;Ruta=$cr.FullName;Tamano="";Match="$($found -join ',')"}
                }
            }catch{}
        }
    }
    foreach($lp in $additionalLaunchers){
        if(Test-Path $lp){
