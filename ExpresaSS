function Scan-Processes {
    $results = @()
    Write-Evidence "[CAPA1] Iniciando escaneo de procesos..."
    
    $blockList = @(
        "vape", "rise", "flux", "tenacity", "novoline", "astral",
        "scorpion", "phoenix", "cloud", "chill", "cotton", "fatal",
        "inertia", "koid", "skye", "snow", "spook", "tap", "sumo",
        "raze", "kronos", "lucid", "exelon", "ghost", "trig", "hvh",
        "bhop", "aimbot", "esp", "wall", "glow", "chams", "silent",
        "triggerbot", "radar", "xray", "spoofer", "inject", "loader",
        "patcher", "crack", "bypass", "cheat", "hack", "injector",
        "selfdestruct", "wipe", "cleanup", "antiforensic",
        "artemiss", "dream", "monkey", "rapid", "clicker", "macro",
        "autoclick", "keystroke", "logitech", "ghub", "lghub",
        "autohotkey", "autoit", "pulover", "recorder"
    )

    $allProcs = Get-Process -ErrorAction SilentlyContinue
    $wmiProcs = @()
    try { $wmiProcs = Get-WmiObject Win32_Process -ErrorAction SilentlyContinue } catch {}
    
    $combined = @{}
    foreach ($p in $allProcs) { $combined[$p.Id] = $p }
    foreach ($p in $wmiProcs) { 
        if (-not $combined.ContainsKey($p.ProcessId)) {
            $fake = New-Object PSObject -Property @{
                Id = $p.ProcessId
                ProcessName = $p.Name
                StartTime = $p.CreationDate
            }
            $combined[$p.ProcessId] = $fake
            Write-Evidence "[!] Proceso OCULTO via WMI: $($p.Name) PID:$($p.ProcessId)"
        }
    }
    
    foreach ($proc in $combined.Values) {
        $name = $proc.ProcessName.ToLower()
        foreach ($block in $blockList) {
            if ($name -like "*$block*" -or $name -eq $block) {
                $path = ""; $startTime = ""
                try { $path = $proc.Path } catch { try { $path = $proc.MainModule.FileName } catch {} }
                try { $startTime = $proc.StartTime } catch {}
                $results += [PSCustomObject]@{
                    Tipo = "PROCESO"; Nombre = $proc.ProcessName; PID = $proc.Id
                    Ruta = $path; Inicio = $startTime; Match = $block
                }
                Write-Evidence "[CAPA1] PROCESO: $($proc.ProcessName) PID:$($proc.Id) match:$block"
            }
        }
    }
    return $results
}

function Scan-Memory {
    $results = @()
    Write-Evidence "[CAPA2] Escaneando DLLs en memoria..."
    
    $suspDlls = @("vape", "rise", "flux", "novoline", "astral", "inject", "hook",
        "loader", "cheat", "hack", "client", "detours", "minhook",
        "easyhook", "mhook", "mdlhud", "opengl32", "d3d", "discordhook",
        "xinput1_3", "ws2_32", "version", "winmm", "dbghelp")
    $targetNames = @("javaw", "java", "minecraft", "chrome", "firefox", "msedge", "opera")
    
    foreach ($target in $targetNames) {
        $procs = Get-Process -Name $target -ErrorAction SilentlyContinue
        foreach ($p in $procs) {
            try {
                $mods = $p.Modules | Where-Object { 
                    $mn = $_.ModuleName.ToLower()
                    ($suspDlls | Where-Object { $mn -like "*$_*" }) -ne $null
                }
                foreach ($mod in $mods) {
                    $results += [PSCustomObject]@{
                        Tipo = "DLL_INYECTADA"; Proceso = $p.ProcessName; PID = $p.Id
                        DLL = $mod.ModuleName; Ruta = $mod.FileName
                    }
                    Write-Evidence "[CAPA2] DLL: $($mod.ModuleName) en $($p.ProcessName) PID:$($p.Id)"
                }
            } catch {}
        }
    }
    return $results
}

function Scan-Disk {
    param([switch]$Deep)
    $results = @()
    Write-Evidence "[CAPA3] Escaneando disco..."
    
    $exts = @("*.jar", "*.exe", "*.dll", "*.ps1", "*.bat", "*.vbs", "*.js", "*.jse", "*.vbe", "*.cmd", "*.scr", "*.com", "*.pif")
    $keywords = @("inject", "hook", "loader", "patcher", "bypass", "cheat", "hack", "vape", "rise",
        "flux", "tenacity", "novoline", "selfdestruct", "destroy", "wipe", "cleanup",
        "rat", "trojan", "keylog", "spy", "steal", "dump", "crack", "keygen")
    $paths = @(
        "$env:USERPROFILE\Desktop", "$env:USERPROFILE\Downloads",
        "$env:USERPROFILE\Documents", "$env:USERPROFILE\AppData\Local\Temp",
        "$env:USERPROFILE\AppData\Roaming\.minecraft", "$env:LOCALAPPDATA\VirtualStore",
        "$env:USERPROFILE\AppData\Roaming", "$env:USERPROFILE\AppData\Local"
    )
    if ($Deep) { $paths += "$env:PROGRAMDATA", "$env:ProgramFiles", "${env:ProgramFiles(x86)}" }
    
    $hace2h = (Get-Date).AddMinutes(-120)
    foreach ($ext in $exts) {
        foreach ($p in $paths) {
            if (Test-Path $p) {
                $files = Get-ChildItem -Path $p -Filter $ext -Recurse -ErrorAction SilentlyContinue |
                    Where-Object { $_.LastWriteTime -gt $hace2h -or $Deep }
                foreach ($f in $files) {
                    $matchKW = $keywords | Where-Object { $f.Name -match $_ } | Select-Object -First 1
                    $results += [PSCustomObject]@{
                        Tipo = "ARCHIVO"; Nombre = $f.Name; Ruta = $f.FullName
                        Tamano = "$([math]::Round($f.Length/1KB,1)) KB"
                        Modificado = $f.LastWriteTime; Match = $matchKW
                    }
                    Write-Evidence "[CAPA3] ARCHIVO: $($f.FullName) $(if($matchKW){'match:'+$matchKW})"
                }
            }
        }
    }
    return $results
}

function Scan-Registry {
    $results = @()
    Write-Evidence "[CAPA4] Escaneando registro, servicios, tareas..."
    
    $keywords = "inject|hook|loader|cheat|hack|vape|rise|flux|bypass|selfdestruct|wipe|cleanup|trojan|keylog"
    
    $runPaths = @(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\SOFTWARE\Wow6432Node\Microsoft\Windows\CurrentVersion\Run",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce"
    )
    foreach ($rp in $runPaths) {
        if (Test-Path $rp) {
            $items = Get-ItemProperty -Path $rp -ErrorAction SilentlyContinue
            foreach ($item in $items.PSObject.Properties) {
                if ($item.Name -match "PSPath|PSParentPath|PSChildName|PSDrive|PSProvider") { continue }
                if ($item.Value -match $keywords) {
                    $results += [PSCustomObject]@{ Tipo = "REGISTRO_RUN"; Ruta = "$rp\$($item.Name)"; Valor = $item.Value }
                    Write-Evidence "[CAPA4] REG: $rp\$($item.Name)"
                }
            }
        }
    }
    
    try {
        $services = Get-WmiObject Win32_Service -ErrorAction SilentlyContinue
        foreach ($s in $services) {
            if ($s.PathName -match $keywords -or $s.Name -match $keywords) {
                $results += [PSCustomObject]@{ Tipo = "SERVICIO"; Nombre = $s.Name; Ruta = $s.PathName; Estado = $s.State }
                Write-Evidence "[CAPA4] SERVICIO: $($s.Name)"
            }
        }
    } catch {}
    
    try {
        $tasks = Get-ScheduledTask -ErrorAction SilentlyContinue
        foreach ($t in $tasks) {
            $actions = "$($t.Actions)"
            if ($actions -match $keywords) {
                $results += [PSCustomObject]@{ Tipo = "TAREA"; Nombre = $t.TaskName; Accion = $actions }
                Write-Evidence "[CAPA4] TAREA: $($t.TaskName)"
            }
        }
    } catch {}
    
    return $results
}

function Scan-Kernel {
    $results = @()
    Write-Evidence "[CAPA5] Escaneando kernel..."
    
    $suspDrivers = @("inject", "hook", "cheat", "hack", "wproc", "dbutil", "speedfan",
        "winio", "winring0", "easydriver", "phymem", "gdrv", "cpuid")
    
    try {
        $drivers = Get-WmiObject Win32_SystemDriver -ErrorAction SilentlyContinue
        foreach ($d in $drivers) {
            $dn = $d.Name.ToLower()
            foreach ($s in $suspDrivers) {
                if ($dn -like "*$s*") {
                    $results += [PSCustomObject]@{ Tipo = "DRIVER"; Nombre = $d.Name; Ruta = $d.PathName; Estado = $d.State }
                    Write-Evidence "[CAPA5] DRIVER: $($d.Name) match:$s"
                }
            }
        }
    } catch {}
    
    try {
        $allServices = Get-WmiObject Win32_Service -ErrorAction SilentlyContinue | Where-Object State -eq Running
        $knownOk = @("nvlddmkm", "dxgkrnl", "win32k", "ntoskrnl", "hal", "ksecdd", "cng",
            "tcpip", "ndis", "volmgr", "partmgr", "fvevol", "mountmgr", "pci", "acpi")
        foreach ($s in $allServices) {
            if ($s.Name -notin $knownOk -and $s.PathName -match '\.sys' -and -not ($s.PathName -match 'System32|SysWOW64|Program Files|Windows')) {
                $results += [PSCustomObject]@{ Tipo = "DRIVER_SOSPECHOSO"; Nombre = $s.Name; Ruta = $s.PathName }
                Write-Evidence "[CAPA5] DRIVER_SOSPECHOSO: $($s.Name)"
            }
        }
    } catch {}
    
    try {
        $targetProcs = @("javaw.exe", "java.exe", "minecraft.exe")
        foreach ($tproc in $targetProcs) {
            $procs = Get-Process -Name ($tproc -replace '\.exe','') -ErrorAction SilentlyContinue
            foreach ($p in $procs) {
                try {
                    $mods = $p.Modules | Where-Object { 
                        $_.ModuleName -match "detours|minhook|easyhook|mhook|hook|inject" -or
