function Test-Admin {
    $currentUser = New-Object Security.Principal.WindowsPrincipal $([Security.Principal.WindowsIdentity]::GetCurrent())
    $currentUser.IsInRole([Security.Principal.WindowsBuiltinRole]::Administrator)
}

if (!(Test-Admin)) {
    Write-Warning "Brother ejecutalo como ADMIN :V"
    Start-Sleep 10
    Exit
}

$sw = [Diagnostics.Stopwatch]::StartNew()
$Desktop = [Environment]::GetFolderPath("Desktop")
$Fecha = Get-Date -Format "yyyy-MM-dd_HH-mm"

Write-Host ""
Write-Host "[1/4] Buscando archivos .jar modificados en los ultimos 20 min..." -ForegroundColor Green
$Jars = cmd /c "forfiles /p C:\ /s /m *.jar /d -20 /c `"cmd /c echo @path @fdate @ftime`"" 2>$null
$JarsLog = Join-Path $Desktop "Jars_20min_$Fecha.txt"
$Jars | Out-File -FilePath $JarsLog -Encoding UTF8
Write-Host "   Encontrados: $($Jars.Count)" -ForegroundColor Cyan

Write-Host "[2/4] Buscando archivos .exe modificados en los ultimos 20 min..." -ForegroundColor Green
$Exes = cmd /c "forfiles /p C:\ /s /m *.exe /d -20 /c `"cmd /c echo @path @fdate @ftime`"" 2>$null
$ExesLog = Join-Path $Desktop "Exes_20min_$Fecha.txt"
$Exes | Out-File -FilePath $ExesLog -Encoding UTF8
Write-Host "   Encontrados: $($Exes.Count)" -ForegroundColor Cyan

Write-Host "[3/4] Buscando archivos .dll modificados en los ultimos 20 min..." -ForegroundColor Green
$Dlls = cmd /c "forfiles /p C:\ /s /m *.dll /d -20 /c `"cmd /c echo @path @fdate @ftime`"" 2>$null
$DllsLog = Join-Path $Desktop "Dlls_20min_$Fecha.txt"
$Dlls | Out-File -FilePath $DllsLog -Encoding UTF8
Write-Host "   Encontrados: $($Dlls.Count)" -ForegroundColor Cyan

Write-Host "[4/4] Buscando archivos eliminados en los ultimos 20 min..." -ForegroundColor Green
$Eliminados = @()
$exesDel = cmd /c "fsutil usn readjournal c: csv | findstr /i /c:`.exe` | findstr /i /c:`"0x80000200`"" 2>$null
$dllsDel = cmd /c "fsutil usn readjournal c: csv | findstr /i /c:`.dll` | findstr /i /c:`"0x80000200`"" 2>$null
$jarsDel = cmd /c "fsutil usn readjournal c: csv | findstr /i /c:`.jar` | findstr /i /c:`"0x80000200`"" 2>$null
$todosDel = $exesDel + $dllsDel + $jarsDel
foreach ($linea in $todosDel) {
    if ($linea -match "ERROR" -or $linea -eq "") { continue }
    $Eliminados += $linea.Trim()
}
$EliminadosLog = Join-Path $Desktop "Eliminados_20min_$Fecha.txt"
$Eliminados | Out-File -FilePath $EliminadosLog -Encoding UTF8
Write-Host "   Eliminados: $($Eliminados.Count)" -ForegroundColor Cyan

$sw.stop()
$t = $sw.Elapsed.TotalMinutes

Write-Host ""
Write-Host "========================================" -ForegroundColor Cyan
Write-Host " ANALISIS COMPLETADO" -ForegroundColor Yellow
Write-Host "========================================" -ForegroundColor Cyan
Write-Host ""
Write-Host "Archivos guardados en el escritorio:" -ForegroundColor White
Write-Host "  - Jars_20min_$Fecha.txt ($($Jars.Count))" -ForegroundColor Green
Write-Host "  - Exes_20min_$Fecha.txt ($($Exes.Count))" -ForegroundColor Green
Write-Host "  - Dlls_20min_$Fecha.txt ($($Dlls.Count))" -ForegroundColor Green
Write-Host "  - Eliminados_20min_$Fecha.txt ($($Eliminados.Count))" -ForegroundColor Green
Write-Host ""
Write-Host "Tiempo: $t Minutos" -ForegroundColor Yellow
Write-Host ""
Write-Host "Presiona ENTER para abrir la carpeta..." -ForegroundColor Yellow
Read-Host
