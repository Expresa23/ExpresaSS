    Write-Host "    Papelera: $($Recycled.Count)" -ForegroundColor White
    Write-Host "    BAM (ejecuciones): $($Bam.Count)" -ForegroundColor White
    Write-Host "    Hooks de inyeccion: $($Hooks.Count)" -ForegroundColor Red
    Write-Host "    Self-destruct: $(if ($Global:SelfDestructDetected) { "DETECTADO!" } else { "No detectado" })"
    Write-Host "  ========================================" -ForegroundColor Red
    Write-Host ""

    Write-Host "  Guardar TODO en TXT? (S/N)" -ForegroundColor Yellow
    if ((Read-Host).ToUpper() -eq "S") {
        $Desktop = [Environment]::GetFolderPath("Desktop")
        $Fecha = Get-Date -Format "yyyy-MM-dd_HH-mm"
@"
AC-BQGE ENHANCED - REPORTE COMPLETO
Fecha: $(Get-Date)
Script: $PSCommandPath
Self-destruct: $(if ($Global:SelfDestructDetected) { "DETECTADO" } else { "No detectado" })

=== ARCHIVOS .JAR ===
$($Jars -join "`n")

=== ARCHIVOS .EXE ===
$($Exes -join "`n")

=== ARCHIVOS .DLL ===
$($Dlls -join "`n")

=== ELIMINADOS (USN) ===
$($Deleted -join "`n")

=== PAPELERA DE RECICLAJE ===
$($Recycled -join "`n")

=== BAM (EJECUCIONES) ===
$($Bam -join "`n")

=== HOOKS DE INYECCION ===
$($Hooks -join "`n")
"@ | Out-File -FilePath "$Desktop\AC-BQGE_Reporte_$Fecha.txt" -Encoding UTF8
        Write-Host "  Reporte guardado en el escritorio." -ForegroundColor Green
    }

    Write-Host ""
    Write-Host "  Presiona ENTER para continuar..."
    Read-Host
}

function Toggle-StealthMode {
    if ($Global:ModoSigiloso) {
        $Global:ModoSigiloso = $false
        $Global:LogFile = $null
        Write-Host "  Modo sigiloso DESACTIVADO" -ForegroundColor Yellow
    } else {
        $Global:ModoSigiloso = $true
        $Desktop = [Environment]::GetFolderPath("Desktop")
        $Global:LogFile = "$Desktop\AC-BQGE_ModoSigiloso_$(Get-Date -Format 'yyyy-MM-dd_HH-mm').log"
        Write-Host "  Modo sigiloso ACTIVADO - Output en: $($Global:LogFile)" -ForegroundColor Green
    }
    Start-Sleep 2
}

# ============================================
# MAIN
# ============================================
if (!(Test-Admin)) {
    Write-Host "  EJECUTA ESTE SCRIPT COMO ADMINISTRADOR" -ForegroundColor Red
    Write-Host "  Algunas funciones no funcionaran correctamente." -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  Presiona ENTER para continuar de todas formas..."
    Read-Host
}

# Self-check inicial
Check-SelfDestruct -NoPause

do {
    Show-Menu
    Write-Host "  Selecciona una opcion: " -ForegroundColor Yellow -NoNewLine
    $option = Read-Host

    switch ($option) {
        "1" { Search-Files -Extension "jar" }
        "2" { Search-Files -Extension "exe" }
        "3" { Search-Files -Extension "dll" }
        "4" {
            Search-Files -Extension "jar"
            Search-Files -Extension "exe"
            Search-Files -Extension "dll"
        }
        "5" { Search-Deleted }
        "6" { Search-BAM }
        "7" { Detect-InjectionHooks }
        "8" { Check-RecycleBin }
        "9" { Check-SelfDestruct }
        "10" { Search-All }
        "11" { Check-Integrity }
        "12" { Toggle-StealthMode }
        "13" {
            Show-Banner
            Write-Host "  Rastreando origen del self-destruct..." -ForegroundColor Red
            $culprits = Get-SelfDestructSource
            if ($culprits.Count -gt 0) {
                Write-Host ""
                Write-Host "  POSIBLES CULPABLES ENCONTRADOS:" -ForegroundColor Yellow
                Write-Host ""
                $count = 1
                foreach ($c in $culprits) {
                    Write-Host "  [$count] $($c.Tipo)" -ForegroundColor White
                    Write-Host "       Nombre: $($c.Nombre)" -ForegroundColor White
                    Write-Host "       Ruta: $($c.Ruta)" -ForegroundColor White
                    if ($c.PID) { Write-Host "       PID: $($c.PID)" -ForegroundColor White }
                    $count++
                }
                Write-Host ""
                Write-Host "  [?] Guardar en TXT? (S/N)" -ForegroundColor Yellow
                if ((Read-Host).ToUpper() -eq "S") {
                    $Desktop = [Environment]::GetFolderPath("Desktop")
                    $Fecha = Get-Date -Format "yyyy-MM-dd_HH-mm"
                    $culprits | Format-Table -AutoSize | Out-File -FilePath "$Desktop\AC-BQGE_SelfDestructSource_$Fecha.txt" -Encoding UTF8
                    Write-Host "  Guardado." -ForegroundColor Green
                }
            } else {
                Write-Host "  No se encontraron posibles origenes." -ForegroundColor Yellow
            }
            Write-Host ""
            Write-Host "  Presiona ENTER para continuar..."
            Read-Host
        }
        "14" {
            Show-Banner
            Write-Host "  Restaurando script..." -ForegroundColor Red
            if (Test-Path $PSCommandPath) {
                Write-Host "  El script ya existe en disco." -ForegroundColor Yellow
                Write-Host "  [?] Sobrescribir? (S/N)" -ForegroundColor Yellow
                if ((Read-Host).ToUpper() -eq "S") {
                    $null = Restore-Script
                }
            } else {
                $restored = Restore-Script
                if ($restored) {
                    Write-Host "  Script restaurado exitosamente!" -ForegroundColor Green
                } else {
                    Write-Host "  No se pudo restaurar." -ForegroundColor Red
                }
            }
            Write-Host ""
            Write-Host "  Presiona ENTER para continuar..."
            Read-Host
        }
        "15" {
            Show-Banner
            Write-Host "  ========================================" -ForegroundColor Red
            Write-Host "     GRACIAS POR USAR AC-BQGE ENHANCED" -ForegroundColor White
            Write-Host "  ========================================" -ForegroundColor Red
            Write-Host ""
            Start-Sleep 2
            Exit
        }
        default {
            Write-Host "  OPCION INVALIDA" -ForegroundColor Red
            Start-Sleep 2
        }
    }
} while ($true)
