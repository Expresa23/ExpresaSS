        $modJars=Get-ChildItem -Path $modsPath -Filter "*.jar" -ErrorAction SilentlyContinue
        foreach($mj in $modJars){
            if($mj.Length -gt 100KB){
                try{
                    $bytes=[System.IO.File]::ReadAllBytes($mj.FullName)
                    $content=[System.Text.Encoding]::UTF8.GetString($bytes)
                    $kws=$Global:CheatKeywords|Where-Object{$_ -and $_.Length -gt 3 -and $content -match [regex]::Escape($_)}|Select-Object -First 3
                    if($kws -and $kws.Count -gt 0){
                        $results+=[PSCustomObject]@{Tipo="MOD_HEURISTICO";Nombre=$mj.Name;Ruta=$mj.FullName;Tamano="$([math]::Round($mj.Length/1KB,1)) KB";Match="$($kws -join ',')"}
