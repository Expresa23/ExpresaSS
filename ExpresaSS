function Get-SelfDestructSource {
    <#
    .SYNOPSIS
    Rastrea el origen del self-destruct (proceso que nos lanzó, 
    tarea programada que nos ejecuta, archivo .bat que nos eliminó) 
    y ofrece restaurar el script desde papelera o respaldo.
    #>

    $culprit = @()
    
    # --- METODO 1: Proceso padre del shell actual (WMI) ---
    try {
        $currentPid = (Get-Process -Id $pid).Id
        $parent = Get-WmiObject -Class Win32_Process -Filter "ProcessId = $currentPid" -ErrorAction SilentlyContinue
        if ($parent) {
            $parentPid = $parent.ParentProcessId
            $parentProc = Get-Process -Id $parentPid -ErrorAction SilentlyContinue
            if ($parentProc) {
                $parentPath = try { $parentProc.Path } catch { try { $parentProc.MainModule.FileName } catch { "Desconocido" } }
                $culprit += [PSCustomObject]@{
                    Tipo = "PADRE (WMI)"
                    Nombre = $parentProc.ProcessName
                    PID = $parentPid
                    Ruta = $parentPath
                    Inicio = $parentProc.StartTime
                }
            }
        }
    } catch {}
    
    # --- METODO 2: Momento de creación (via Get-Process -IncludeUserName) ---
    # Intentamos encontrar el ultimo proceso que abrió powershell
    try {
        $recentProcs = Get-Process -Name "powershell","pwsh","cmd" -ErrorAction SilentlyContinue | 
            Where-Object { $_.StartTime -gt $Global:FechaInicio -and $_.Id -ne $pid } |
            Sort-Object StartTime -Descending
        
        foreach ($rp in $recentProcs) {
            $rpPath = try { $rp.Path } catch { try { $rp.MainModule.FileName } catch { "Desconocido" } }
            $culprit += [PSCustomObject]@{
                Tipo = "PROCESO (Recientes)"
                Nombre = $rp.ProcessName
                PID = $rp.Id
                Ruta = $rpPath
                Inicio = $rp.StartTime
            }
        }
    } catch {}
    
    # --- METODO 3: Checksum del evento de seguridad específico para este script ---
    try {
        $events = Get-WinEvent -LogName 'Security' -FilterXPath "*[System[EventID=4688]]" -MaxEvents 50 -ErrorAction SilentlyContinue
        foreach ($e in $events) {
            if ($e.TimeCreated -gt $Global:FechaInicio) {
                $msg = $e.Message
                if ($msg -match [regex]::Escape($PSCommandPath) -or $msg -match "powershell.*-File.*AC-BQGE|pwsh.*-File") {
                    # Extraer el proceso padre que ejecutó este comando
                    if ($msg -match -join "Account Name:\s+(.+)") {}
                    $culprit += [PSCustomObject]@{
                        Tipo = "EVENTO (4688)"
                        Nombre = "($e.TimeCreated)"
                        Ruta = $msg
                    }
                }
            }
        }
    } catch {}

    # --- METODO 4: Tareas programadas que nos referencian ---
    try {
        $tasks = Get-ScheduledTask -ErrorAction SilentlyContinue
        foreach ($t in $tasks) {
            $actions = $t.Actions
            if ($actions -match [regex]::Escape($PSCommandPath)) {
                $culprit += [PSCustomObject]@{
                    Tipo = "TAREA PROGRAMADA"
                    Nombre = $t.TaskName
                    Ruta = $t.TaskPath
                    Inicio = $t.Date
                }
            }
        }
    } catch {}

    # --- METODO 5: Buscar en BAM la ultima ejecución de algo que coincida ---
    try {
        $bamRoot = "HKLM:\SYSTEM\CurrentControlSet\Services\bam\UserSettings\"
        $Users = Get-ChildItem -Path $bamRoot -ErrorAction SilentlyContinue | Select-Object -ExpandProperty PSChildName
        foreach ($Sid in $Users) {
            $BamItems = Get-ItemProperty -Path "$bamRoot$Sid" -ErrorAction SilentlyContinue
            foreach ($Item in $BamItems.PSObject.Properties) {
                if ($Item.Name -match "PSPath|PSParentPath|PSChildName|PSDrive|PSProvider") { continue }
                $Key = $Item.Value
                if ($Key.Length -ge 8 -and $Item.Name -match "AC-BQGE|selfdestruct|cleanup|wipe" -and $Item.Name -notmatch $PSCommandPath) {
                    $Hex = [System.BitConverter]::ToString($Key[7..0]) -replace "-",""
                    $TimeUser = [DateTime]::FromFileTimeUtc([Convert]::ToInt64($Hex, 16))
                    $path = $Item.Name -replace '\\Device\\HarddiskVolume\d+\\', 'C:\'
                    $culprit += [PSCustomObject]@{
                        Tipo = "BAM (Ejecución)"
                        Nombre = "Sospechoso"
                        Ruta = $path
                        Inicio = $TimeUser
                    }
                }
            }
        }
    } catch {}

    return $culprit
}

function Restore-Script {
    <#
    .SYNOPSIS
    Restaura el script desde papelera de reciclaje o desde respaldo temporal.
    #>
    $restored = $false
    $scriptName = Split-Path $PSCommandPath -Leaf

    # Intento 1: Buscar en papelera de reciclaje
    try {
        $shell = New-Object -ComObject Shell.Application
        $recycleBin = $shell.NameSpace(0xa)
        foreach ($item in $recycleBin.Items()) {
            if ($item.Name -eq $scriptName) {
                $origPath = $item.ExtendedProperty("System.Recycle.OriginalLocation")
                Write-Host "  [!] Archivo encontrado en papelera (origen: $origPath)" -ForegroundColor Yellow
                Write-Host "  [?] Desea restaurarlo? (S/N)" -ForegroundColor Yellow
                if ((Read-Host).ToUpper() -eq "S") {
                    try {
                        $recycleBin.MoveHere($item.Path)
                        Write-Host "  [+] Restaurado a ubicacion original." -ForegroundColor Green
                        $restored = $true
                    } catch {
                        Write-Host "  [-] Error al restaurar: $_" -ForegroundColor Red
                    }
                }
                break
            }
        }
        [System.Runtime.InteropServices.Marshal]::ReleaseComObject($shell) | Out-Null
    } catch {
        Write-Host "  [-] Error al leer papelera: $_" -ForegroundColor Red
    }

    # Intento 2: Buscar en el respaldo del sistema (Volume Shadow Copy)
    if (-not $restored) {
        try {
            $vss = Get-WmiObject -Class Win32_ShadowCopy -ErrorAction SilentlyContinue
            if ($vss) {
                Write-Host "  [?] Revisar Volume Shadow Copy? (S/N)" -ForegroundColor Yellow
                if ((Read-Host).ToUpper() -eq "S") {
                    foreach ($sc in $vss) {
                        $pathOrig = $PSCommandPath -replace ':','$'  # roughly
                        try {
                            $wi = [wmi]$sc.__PATH
                            $wi.Create("C:\\")
                        } catch {}
                    }
                }
            }
        } catch {}
    }

    # Intento 3: Buscar en Temp/cache del script
    if (-not $restored) {
        $respaldos = @(
            "$env:TEMP\AC-BQGE*",
            "$env:TEMP\*.ps1.bak",
            "$env:TEMP\*.ps1.backup"
        )
        foreach ($pat in $respaldos) {
            $files = Get-ChildItem -Path $pat -ErrorAction SilentlyContinue
            foreach ($f in $files) {
                Write-Host "  [+] Respaldo encontrado: $($f.FullName)"
                Write-Host "  [?] Desea restaurarlo? (S/N)"
                if ((Read-Host).ToUpper() -eq "S") {
                    $f.CopyTo($PSCommandPath, $true)
                    Write-Host "  Script restaurado!" -ForegroundColor Green
                    $restored = $true
                    break
                }
            }
        }
    }

    # Intento 4: Recrear el script desde la memoria actual
    if (-not $restored -and -not (Test-Path $PSCommandPath)) {
        Write-Host "  [!] El script no existe en disco y no se encuentra en papelera." -ForegroundColor Red
        Write-Host "  [?] Desea recrear el script desde la sesion actual (corriendo en memoria)? (S/N)" -ForegroundColor Yellow
        if ((Read-Host).ToUpper() -eq "S") {
            $parentDir = Split-Path $PSCommandPath -Parent
            if (-not (Test-Path $parentDir)) { mkdir $parentDir -Force | Out-Null }
            $null = Read-Host -Prompt "  Dale ENTER para recrear el script en $PSCommandPath"
            $myContent = Get-Content -Path "\\?\GLOBALROOT\Device\HarddiskVolume1\..." -ErrorAction SilentlyContinue
            if (-not $myContent) {
                # Can't read from memory directly, try to recreate from current execution
                $source = (Get-PSCallStack | Select-Object -First 1).ScriptName
                if ($source -and $source -ne "" -and $source -ne "No file") {
                    try {
                        $content = (Get-Content $source -Raw -ErrorAction Stop)
                        if ($content) {
                            Set-Content -Path $PSCommandPath -Value $content -Encoding UTF8
                            Write-Host "  Script recreado desde el source original!" -ForegroundColor Green
                            $restored = $true
                        }
                    } catch {
                        Write-Host "  No se pudo recrear." -ForegroundColor Red
                    }
                } else {
                    # Sesion solo en memoria (e.g. -Command)
                    try {
                        $myScript = (Get-PSCallStack)[-1].Position.File
                        if ($myScript -and $myScript -ne "") {
                            Copy-Item -Path $myScript -Destination $PSCommandPath -Force -ErrorAction Stop
                            Write-Host "  Script recreado!" -ForegroundColor Green
                            $restored = $true
                        }
                    } catch {}
                }
            }
        }
    }

    return $restored
}

function Check-SelfDestruct {
    param([switch]$NoPause)
    Show-Banner
    Write-Host "  [SELF-CHECK] DETECTANDO AUTO-BORRADO..." -ForegroundColor Red
    Write-Host ""

    $sospechas = @()
    $Hace2h = (Get-Date).AddMinutes(-120)
    $Global:SelfDestructCulprit = @()
    $Global:SelfDestructMethod = $null

    if (-not (Test-Path $PSCommandPath)) {
        $sospechas += "[CRITICO] El script ha sido ELIMINADO del disco"
        $Global:SelfDestructDetected = $true
        $Global:SelfDestructMethod = "ELIMINACION"
    }

    Write-Host "  [1/5] Buscando tareas programadas sospechosas..." -ForegroundColor White
    try {
        $tasks = Get-ScheduledTask -ErrorAction SilentlyContinue | Where-Object {
            $_.Actions -match "del|remove|erase|clean|wipe|self.destruct|cleanup|destroy|purge|delete"
        }
        foreach ($t in $tasks) {
            $sospechas += "[TAREA] Tarea programada: $($t.TaskName) - Accion sospechosa"
            Write-Host "      - $($t.TaskName)" -ForegroundColor Red
        }
    } catch {}

    Write-Host "  [2/5] Buscando procesos con handles a este script..." -ForegroundColor White
    try {
        $openHandles = & "cmd.exe" "/C handle.exe -a -p ""$PSCommandPath"" 2>nul" 2>$null
        if ($LASTEXITCODE -eq 0 -and $openHandles) {
            $sospechas += "[HANDLE] Procesos mantienen abierto el script: $openHandles"
            Write-Host "      - $openHandles" -ForegroundColor Red
        }
    } catch {}

    Write-Host "  [3/5] Verificando permisos del script..." -ForegroundColor White
    try {
        $acl = Get-Acl -Path $PSCommandPath -ErrorAction SilentlyContinue
        if (-not $acl) {
            $sospechas += "[CRITICO] No se puede leer ACL del script - posible eliminacion en curso"
            $Global:SelfDestructMethod = "ELIMINACION_ACL"
        }
    } catch {
        $sospechas += "[CRITICO] Error al leer permisos - el archivo puede estar siendo borrado"
        $Global:SelfDestructMethod = "ELIMINACION_PERMISOS"
    }

    Write-Host "  [4/5] Verificando eventos de eliminacion en Security Log..." -ForegroundColor White
    try {
        $events = Get-WinEvent -LogName 'Security' -FilterXPath "*[System[EventID=4663]]" -MaxEvents 100 -ErrorAction SilentlyContinue
        foreach ($e in $events) {
            if ($e.TimeCreated -gt $Hace2h) {
                $msg = $e.Message
                if ($msg -match [regex]::Escape($PSCommandPath)) {
                    # Extract process that performed the access
                    $procName = "?"
                    $procPid = "?"
                    if ($msg -match "Process Name:\s+(.+?)(\r|\n)") { $procName = $matches[1].Trim() }
                    if ($msg -match "Process ID:\s+(\d+)") { $procPid = $matches[1] }
                    $sospechas += "[EVENTO] Intento de acceso/eliminacion al script: $($e.TimeCreated) - Proc: $procName ($procPid)"
                    Write-Host "      - Time: $($e.TimeCreated) | Proc: $procName PID:$procPid" -ForegroundColor Red
                }
            }
        }
    } catch {}

    Write-Host "  [5/5] Verificando archivos .bat/.cmd temporales que referencien autoeliminacion..." -ForegroundColor White
    $tempBats = Get-ChildItem -Path "$env:TEMP" -Filter "*.*" -Recurse -ErrorAction SilentlyContinue |
        Where-Object { $_.LastWriteTime -gt $Hace2h -and $_.Extension -match '\.(bat|cmd|ps1|vbs|js|jse)' }
    foreach ($scriptFile in $tempBats) {
        try {
            $content = Get-Content -Path $scriptFile.FullName -Raw -ErrorAction SilentlyContinue
            if ($content -match "self.destruct|del.*\.ps1|erase.*\.ps1|cleanup|wipe|Remove-Item.*ps1") {
                $sospechas += "[SCRIPT] Archivo con instrucciones de autoeliminacion: $($scriptFile.FullName)"
                Write-Host "      - $($scriptFile.Name)" -ForegroundColor Red
            }
        } catch {}
    }

    # Intentar rastrear el origen
    $culprits = Get-SelfDestructSource
    
    Write-Host ""
    Write-Host "  ========================================" -ForegroundColor Red
    Write-Host "  RESULTADOS SELF-CHECK:" -ForegroundColor White
    Write-Host "  ========================================" -ForegroundColor Red
    Write-Host ""

    if ($sospechas.Count -gt 0) {
        Write-Host "  [!] SE DETECTARON $($sospechas.Count) INDICIOS DE SELF-DESTRUCT" -ForegroundColor Red
        Write-Host ""
        foreach ($s in $sospechas) {
            Write-Host "  $s"
        }
        $Global:SelfDestructDetected = $true
        Write-Host ""

        # --- MOSTRAR EL CULPABLE ---
        if ($culprits.Count -gt 0) {
            Write-Host "  ========================================" -ForegroundColor Red
            Write-Host "  RASTREO DE CULPABLES:"
            Write-Host "  ========================================" -ForegroundColor Red
            $Global:SelfDestructCulprit = $culprits
            $count = 1
            foreach ($c in $culprits) {
                Write-Host ""
                Write-Host "  [$count] $($c.Tipo):" -ForegroundColor Yellow
                Write-Host "      Nombre: $($c.Nombre)"
                Write-Host "      Ruta: $($c.Ruta)"
                Write-Host "      PID: $($c.PID)"
                if ($c.Inicio) { Write-Host "      Hora: $($c.Inicio)" }
                $count++
            }
        }

        # --- SI EL SCRIPT FUE ELIMINADO, OFRECER RESTAURAR ---
        if (-not (Test-Path $PSCommandPath)) {
            Write-Host ""
            Write-Host "  [!] Script eliminado de disco!" -ForegroundColor Red
            Write-Host "  [?] Desea intentar restaurarlo? (S/N)" -ForegroundColor Yellow
            if ((Read-Host).ToUpper() -eq "S") {
                $restored = Restore-Script
                if ($restored) {
                    Write-Host "  [+] Script restaurado exitosamente!" -ForegroundColor Green
                }
            }
        } else {
            # Script existe - ofrecer guardar los datos del culpable
            Write-Host ""
            Write-Host "  [?] Guardar informacion del origen en TXT? (S/N)" -ForegroundColor Yellow
            if ((Read-Host).ToUpper() -eq "S") {
                $Desktop = [Environment]::GetFolderPath("Desktop")
                $Fecha = Get-Date -Format "yyyy-MM-dd_HH-mm"
                @"
AC-BQGE SELF-DESTRUCT SOURCE REPORT
Fecha: $(Get-Date)
Script: $PSCommandPath

--- CULPABLES RASTREADOS ---

$($culprits | Format-Table -AutoSize | Out-String)

--- SOSPECHAS DETECTADAS ---

$($sospechas -join "`n")
"@ | Out-File -FilePath "$Desktop\AC-BQGE_SelfDestructSource_$Fecha.txt" -Encoding UTF8
                Write-Host "  Guardado." -ForegroundColor Green
            }
        }
    } else {
        Write-Host "  No se encontraron indicios de auto-borrado." -ForegroundColor Green
        Write-Host "  El script parece seguro." -ForegroundColor Green
    }

    if (-not $NoPause) {
        Write-Host ""
        Write-Host "  Presiona ENTER para continuar..." -ForegroundColor White
        Read-Host
    }
}

function Search-Files {
    param([string]$Extension)

    Show-Banner
    Write-Host "  BUSCANDO ARCHIVOS .$Extension (ULTIMAS 2 HORAS)..." -ForegroundColor Red
    Write-Host ""

    $Paths = @(
        "$env:USERPROFILE\Desktop",
        "$env:USERPROFILE\Downloads",
        "$env:USERPROFILE\Documents",
        "$env:USERPROFILE\AppData\Local\Temp",
        "$env:USERPROFILE\AppData\Roaming\.minecraft",
        "$env:LOCALAPPDATA\VirtualStore",
        "$env:USERPROFILE\AppData\Local\Programs",
        "$env:USERPROFILE\AppData\Roaming"
    )

    $Results = @()
    $Hace2h = (Get-Date).AddMinutes(-120)

    foreach ($p in $Paths) {
        if (Test-Path $p -ErrorAction SilentlyContinue) {
            $Results += Get-ChildItem -Path $p -Filter "*.$Extension" -Recurse -ErrorAction SilentlyContinue |
                Where-Object { $_.LastWriteTime -gt $Hace2h } |
                ForEach-Object { "$($_.FullName) - $($_.LastWriteTime) - $($_.Length) bytes" }
        }
    }

    if ($Results.Count -gt 0) {
        Write-Host "  ENCONTRADOS: $($Results.Count)" -ForegroundColor Green
        Write-Host ""
        foreach ($r in $Results) { Write-Host "  $r" -ForegroundColor White }
    } else {
        Write-Host "  NO SE ENCONTRARON ARCHIVOS .$Extension EN LAS ULTIMAS 2 HORAS" -ForegroundColor Yellow
    }

    Write-Host ""
    Write-Host "  Guardar lista en TXT? (S/N)" -ForegroundColor Yellow
    if ((Read-Host).ToUpper() -eq "S") {
        $Desktop = [Environment]::GetFolderPath("Desktop")
        $Results | Out-File -FilePath "$Desktop\AC-BQGE_$Extension.txt" -Encoding UTF8
        Write-Host "  Guardado en el escritorio." -ForegroundColor Green
    }
    Write-Host ""
    Write-Host "  Presiona ENTER para continuar..."
    Read-Host
}

function Search-Deleted {
    Show-Banner
    Write-Host "  BUSCANDO ARCHIVOS ELIMINADOS (USN JOURNAL + EVENTOS)..." -ForegroundColor Red
    Write-Host ""

    $Results = @()
    $usnFile = "$env:TEMP\usn_scan.txt"

    Write-Host "  [1/2] Leyendo USN Journal (puede tardar hasta 30s)..." -ForegroundColor White
    try {
        $psi = New-Object System.Diagnostics.ProcessStartInfo
        $psi.FileName = "cmd.exe"
        $psi.Arguments = "/C fsutil usn readjournal c: csv > `"$usnFile`""
        $psi.UseShellExecute = $false
        $psi.WindowStyle = [System.Diagnostics.ProcessWindowStyle]::Hidden
        $psi.CreateNoWindow = $true
        $p = [System.Diagnostics.Process]::Start($psi)
        if (-not $p.WaitForExit(30000)) {
            $p.Kill()
            Write-Host "      USN Journal: Timeout (30s)" -ForegroundColor Yellow
        }
    } catch {
        Write-Host "      Error al ejecutar fsutil" -ForegroundColor Yellow
    }

    if (Test-Path $usnFile) {
        $raw = Get-Content $usnFile -TotalCount 100000 -ErrorAction SilentlyContinue
        $Lines = $raw | Select-String -Pattern '\.(exe|dll|jar|ps1|bat|vbs|js|vbe|cmd)' |
            Select-String -Pattern '0x80000200|0x80000000'
        foreach ($line in $Lines) {
            $tipo = if ($line -match '0x80000200') { "ELIMINADO" } else { "RENOMBRADO" }
            $Results += "[$tipo] $line"
        }
        Remove-Item $usnFile -Force -ErrorAction SilentlyContinue
    }

    Write-Host "  [2/2] Verificando Eventos de Seguridad (Windows Audit)..." -ForegroundColor White
    $Hace2h = (Get-Date).AddMinutes(-120)
    try {
        $events = Get-WinEvent -LogName 'Security' -FilterXPath "*[System[EventID=4663]]" -MaxEvents 200 -ErrorAction SilentlyContinue
