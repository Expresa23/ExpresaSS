$ExcludePaths = @(
    "C:\Windows\", "C:\Windows\System32\", "C:\Windows\SysWOW64\",
    "C:\Program Files\", "C:\Program Files (x86)\",
    "C:\Windows\WinSxS\", "C:\Windows\Microsoft.NET\",
    "C:\Windows\assembly\", "C:\Windows\servicing\",
    "C:\Windows\Installer\", "C:\Windows\SystemApps\",
    "C:\$Recycle.Bin\", "C:\System Volume Information\"
)

function Is-ExcludedPath {
    param([string]$Path)
    foreach ($excl in $ExcludePaths) {
        if ($Path -like "$excl*") { return $true }
    }
    return $false
}

function Is-Suspicious {
    param([string]$Path)
    $lower = $Path.ToLower()
    foreach ($kw in $Keywords) {
        if ($lower -match $kw) { return $true }
    }
    return $false
}

Write-Host "[1/7] Buscando archivos .exe y .dll sospechosos..." -ForegroundColor Green
$Sospechosos = @()
$Archivos = Get-ChildItem -Path C:\ -Include *.exe,*.dll -Recurse -ErrorAction SilentlyContinue
foreach ($archivo in $Archivos) {
    if (Is-Suspicious -Path $archivo.FullName) {
        $Sospechosos += [PSCustomObject]@{
            'Archivo' = $archivo.FullName
            'Nombre' = $archivo.Name
            'Extension' = $archivo.Extension
            'Tamaño_KB' = [math]::Round($archivo.Length / 1KB, 2)
            'Creado' = $archivo.CreationTime
            'Modificado' = $archivo.LastWriteTime
            'Firma' = Get-Signature -FilePath $archivo.FullName
        }
    }
}
$SospechososLog = Join-Path $Folder "1_Archivos_Sospechosos.txt"
$Sospechosos | Format-Table -AutoSize | Out-String | Out-File -FilePath $SospechososLog -Encoding UTF8
Write-Host "   Encontrados: $($Sospechosos.Count)" -ForegroundColor Cyan

Write-Host "[2/7] Extrayendo BAM (Ultimos ejecutados)..." -ForegroundColor Green
if (!(Get-PSDrive -Name HKLM -PSProvider Registry)){
    Try{New-PSDrive -Name HKLM -PSProvider Registry -Root HKEY_LOCAL_MACHINE}
    Catch{Write-Warning "Error montando HKEY_Local_Machine"}
}
$bv = ("bam", "bam\State")
Try{$Users = foreach($ii in $bv){Get-ChildItem -Path "HKLM:\SYSTEM\CurrentControlSet\Services\$($ii)\UserSettings\" | Select-Object -ExpandProperty PSChildName}}
Catch{ $Users = @() }

$rpath = @("HKLM:\SYSTEM\CurrentControlSet\Services\bam\","HKLM:\SYSTEM\CurrentControlSet\Services\bam\state\")
$UserBias = (Get-ItemProperty -Path "HKLM:\SYSTEM\CurrentControlSet\Control\TimeZoneInformation").ActiveTimeBias

$Bam = @()
foreach ($Sid in $Users) {
    foreach($rp in $rpath) {
        $BamItems = Get-Item -Path "$($rp)UserSettings\$Sid" -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Property
        Try { $User = (New-Object System.Security.Principal.SecurityIdentifier($Sid)).Translate([System.Security.Principal.NTAccount]).Value }
        Catch { $User = "Sistema" }
        foreach ($Item in $BamItems) {
            $Key = Get-ItemProperty -Path "$($rp)UserSettings\$Sid" -ErrorAction SilentlyContinue | Select-Object -ExpandProperty $Item
            if ($Key.Length -eq 24) {
                $Hex = [System.BitConverter]::ToString($key[7..0]) -replace "-",""
                $TimeUser = (Get-Date ([DateTime]::FromFileTimeUtc([Convert]::ToInt64($Hex, 16))).AddMinutes(-([convert]::ToInt32([Convert]::ToString($UserBias,2),2))/60) -Format "yyyy-MM-dd HH:mm:ss")
                $path = $Item -replace "\\Device\\HarddiskVolume\d+\\", "C:\"
                if (Is-Suspicious -Path $path) {
                    $Bam += [PSCustomObject]@{
                        'Tiempo' = $TimeUser
                        'Archivo' = $path
                        'Usuario' = $User
                        'SID' = $Sid
                        'Firma' = Get-Signature -FilePath $path
                    }
                }
            }
        }
    }
}
$BamLog = Join-Path $Folder "2_BAM_Ejecutados.txt"
$Bam | Format-Table -AutoSize | Out-String | Out-File -FilePath $BamLog -Encoding UTF8
Write-Host "   Encontrados en BAM: $($Bam.Count)" -ForegroundColor Cyan

Write-Host "[3/7] Buscando procesos activos sospechosos..." -ForegroundColor Green
$Procesos = @()
$ProcesosActivos = Get-Process | Where-Object { $_.Path -and (Is-Suspicious -Path $_.Path) }
foreach ($proc in $ProcesosActivos) {
    $Procesos += [PSCustomObject]@{
        'Proceso' = $proc.ProcessName
        'PID' = $proc.Id
        'Ruta' = $proc.Path
        'Firma' = Get-Signature -FilePath $proc.Path
    }
}
$ProcesosLog = Join-Path $Folder "3_Procesos_Activos.txt"
$Procesos | Format-Table -AutoSize | Out-String | Out-File -FilePath $ProcesosLog -Encoding UTF8
