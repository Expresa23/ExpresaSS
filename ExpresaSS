function Scan-MinecraftFolder {
    $results = @()
    Write-Evidence "[CAPA3] Escaneando .minecraft y mods..."
    
    $mcPaths = @(
        "$env:USERPROFILE\AppData\Roaming\.minecraft",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\mods",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\versions",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\config",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\logs",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\crash-reports",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\libraries",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\resourcepacks",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\saves",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\launcher_profiles.json",
        "$env:USERPROFILE\AppData\Roaming\.minecraft\launcher_accounts.json"
    )
    
    # Launchers alternativos
    $additionalLaunchers = @(
        "$env:USERPROFILE\AppData\Roaming\PrismLauncher\instances",
        "$env:USERPROFILE\AppData\Roaming\MultiMC\instances",
        "$env:USERPROFILE\AppData\Roaming\CurseForge\Minecraft\Instances",
        "$env:USERPROFILE\AppData\Roaming\ModrinthApp\profiles",
        "$env:USERPROFILE\AppData\Local\Programs\LunarClient",
        "$env:USERPROFILE\AppData\Roaming\.feather",
        "$env:USERPROFILE\AppData\Roaming\ATLauncher"
    )
    
    # Buscar carpetas ocultas de cheats en .minecraft y directorio home
    $homePaths = @(
        "$env:USERPROFILE",
        "$env:USERPROFILE\AppData\Roaming\.minecraft",
        "$env:USERPROFILE\AppData\Roaming",
        "$env:USERPROFILE\AppData\Local"
    )
    
    foreach ($hp in $homePaths) {
        if (Test-Path $hp) {
            try {
                $dirs = Get-ChildItem -Path $hp -Directory -Force -ErrorAction SilentlyContinue |
                    Where-Object { $_.Name -in $Global:CheatFolders -or ($Global:CheatFolders | Where-Object { $_.Name -like "*$_*" }) }
                foreach ($d in $dirs) {
                    $results += [PSCustomObject]@{
                        Tipo = "CARPETA_CHEAT"; Nombre = $d.Name; Ruta = $d.FullName
                        Tamano = ""; Match = $d.Name
                    }
                    Write-Evidence "[CAPA3] CARPETA_CHEAT: $($d.FullName)"
                }
            } catch {}
        }
    }
    
    # Buscar mods maliciosos en .minecraft/mods/
    $modsPath = "$env:USERPROFILE\AppData\Roaming\.minecraft\mods"
    if (Test-Path $modsPath) {
        $mods = Get-ChildItem -Path $modsPath -Filter "*.jar" -ErrorAction SilentlyContinue
        foreach ($m in $mods) {
            $match = $Global:JarClients | Where-Object { $m.Name.ToLower() -match $_ } | Select-Object -First 1
            if ($match) {
                $results += [PSCustomObject]@{
                    Tipo = "MOD_SOSPECHOSO"; Nombre = $m.Name; Ruta = $m.FullName
                    Tamano = "$([math]::Round($m.Length/1KB,1)) KB"; Match = $match
                }
                Write-Evidence "[CAPA3] MOD: $($m.FullName) match:$match"
            }
        }
        
        $modJars = Get-ChildItem -Path $modsPath -Filter "*.jar" -ErrorAction SilentlyContinue
        foreach ($mj in $modJars) {
            if ($mj.Length -gt 100KB) {
                try {
                    $bytes = [System.IO.File]::ReadAllBytes($mj.FullName)
                    $content = [System.Text.Encoding]::UTF8.GetString($bytes)
                    $kws = $Global:CheatKeywords | Where-Object { $content -match $_ } | Select-Object -First 3
                    if ($kws -and $kws.Count -gt 0) {
                        $results += [PSCustomObject]@{
                            Tipo = "MOD_HEURISTICO"; Nombre = $mj.Name; Ruta = $mj.FullName
                            Tamano = "$([math]::Round($mj.Length/1KB,1)) KB"; Match = "$($kws -join ',')"
                        }
                        Write-Evidence "[CAPA3] MOD_HEURISTICO: $($mj.FullName) keywords:$($kws -join ',')"
                    }
                } catch {}
            }
        }
    }
    
    # Buscar versiones de cheats en .minecraft/versions/
    $versionsPath = "$env:USERPROFILE\AppData\Roaming\.minecraft\versions"
    if (Test-Path $versionsPath) {
        $versions = Get-ChildItem -Path $versionsPath -Directory -ErrorAction SilentlyContinue
        foreach ($v in $versions) {
            $match = $Global:JarClients | Where-Object { $v.Name.ToLower() -match $_ } | Select-Object -First 1
            if ($match) {
                $results += [PSCustomObject]@{
                    Tipo = "VERSION_CHEAT"; Nombre = $v.Name; Ruta = $v.FullName
                    Tamano = ""; Match = $match
                }
                Write-Evidence "[CAPA3] VERSION_CHEAT: $($v.FullName)"
            }
        }
    }
    
    # Buscar configs de cheats en .minecraft/config/
    $configPath = "$env:USERPROFILE\AppData\Roaming\.minecraft\config"
    if (Test-Path $configPath) {
        $configs = Get-ChildItem -Path $configPath -ErrorAction SilentlyContinue
        foreach ($c in $configs) {
            $match = $Global:CheatFolders | Where-Object { $c.Name.ToLower() -match $_ } | Select-Object -First 1
            if ($match) {
                $results += [PSCustomObject]@{
                    Tipo = "CONFIG_CHEAT"; Nombre = $c.Name; Ruta = $c.FullName
                    Tamano = ""; Match = $match
                }
                Write-Evidence "[CAPA3] CONFIG_CHEAT: $($c.FullName)"
            }
        }
    }
    
    # Analizar logs de Minecraft
    $logsPath = "$env:USERPROFILE\AppData\Roaming\.minecraft\logs"
    if (Test-Path $logsPath) {
        $logFiles = Get-ChildItem -Path $logsPath -Filter "*.log" -ErrorAction SilentlyContinue
        foreach ($lf in $logFiles) {
            try {
                $content = Get-Content $lf.FullName -Tail 2000 -ErrorAction SilentlyContinue
                $foundKeywords = $Global:CheatKeywords | Where-Object { 
                    $_ -and $_.Length -gt 3 -and $content -match [regex]::Escape($_)
                } | Select-Object -First 3
                if ($foundKeywords) {
                    $results += [PSCustomObject]@{
                        Tipo = "LOG_CHEAT"; Nombre = $lf.Name; Ruta = $lf.FullName
                        Tamano = "$([math]::Round($lf.Length/1KB,1)) KB"; Match = "$($foundKeywords -join ',')"
                    }
                    Write-Evidence "[CAPA3] LOG_CHEAT: $($lf.Name) match:$($foundKeywords -join ',')"
                }
            } catch {}
        }
    }
    
    # Analizar crash-reports
    $crashPath = "$env:USERPROFILE\AppData\Roaming\.minecraft\crash-reports"
    if (Test-Path $crashPath) {
        $crashes = Get-ChildItem -Path $crashPath -Filter "*.txt" -ErrorAction SilentlyContinue
        foreach ($cr in $crashes) {
            try {
                $content = Get-Content $cr.FullName -Raw -ErrorAction SilentlyContinue
                $found = $Global:JarClients | Where-Object { $content -match $_ } | Select-Object -First 2
                if ($found) {
                    $results += [PSCustomObject]@{
                        Tipo = "CRASH_CHEAT"; Nombre = $cr.Name; Ruta = $cr.FullName
                        Tamano = ""; Match = "$($found -join ',')"
                    }
                    Write-Evidence "[CAPA3] CRASH_CHEAT: $($cr.Name)"
                }
            } catch {}
        }
    }
    
    # Launchers alternativos
    foreach ($lp in $additionalLaunchers) {
        if (Test-Path $lp) {
            $items = Get-ChildItem -Path $lp -ErrorAction SilentlyContinue
            foreach ($it in $items) {
                $match = $Global:JarClients | Where-Object { $it.Name.ToLower() -match $_ } | Select-Object -First 1
                if ($match) {
                    $results += [PSCustomObject]@{
                        Tipo = "LAUNCHER_ITEM"; Nombre = $it.Name; Ruta = $it.FullName
                        Tamano = ""; Match = $match
                    }
                    Write-Evidence "[CAPA3] LAUNCHER: $($it.FullName)"
                }
            }
        }
    }
    
    return $results
}

# ============================================
# CAPA 4: REGISTRO, SERVICIOS, TAREAS
# ============================================

function Scan-Registry {
    $results = @()
    Write-Evidence "[CAPA4] Escaneando registro, servicios, tareas..."
    
    $runPaths = @(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\SOFTWARE\Wow6432Node\Microsoft\Windows\CurrentVersion\Run",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce"
    )
    foreach ($rp in $runPaths) {
        if (Test-Path $rp) {
            $items = Get-ItemProperty -Path $rp -ErrorAction SilentlyContinue
            foreach ($item in $items.PSObject.Properties) {
                if ($item.Name -match "PSPath|PSParentPath|PSChildName|PSDrive|PSProvider") { continue }
                if ($item.Value -match $Global:KeywordRegex) {
                    $results += [PSCustomObject]@{ Tipo = "REGISTRO_RUN"; Ruta = "$rp\$($item.Name)"; Valor = $item.Value }
                    Write-Evidence "[CAPA4] REG: $rp\$($item.Name)"
                }
            }
        }
    }
    
    try {
        $services = Get-WmiObject Win32_Service -ErrorAction SilentlyContinue
        foreach ($s in $services) {
            if ($s.PathName -match $Global:KeywordRegex -or $s.Name -match $Global:KeywordRegex) {
                $results += [PSCustomObject]@{ Tipo = "SERVICIO"; Nombre = $s.Name; Ruta = $s.PathName; Estado = $s.State }
                Write-Evidence "[CAPA4] SERVICIO: $($s.Name)"
            }
        }
    } catch {}
    
    try {
        $tasks = Get-ScheduledTask -ErrorAction SilentlyContinue
        foreach ($t in $tasks) {
            $actions = "$($t.Actions)"
            if ($actions -match $Global:KeywordRegex) {
                $results += [PSCustomObject]@{ Tipo = "TAREA"; Nombre = $t.TaskName; Accion = $actions }
                Write-Evidence "[CAPA4] TAREA: $($t.TaskName)"
            }
        }
    } catch {}
    
    return $results
}

