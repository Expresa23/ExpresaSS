                    if($prop.Name -match "PSPath|PS"){continue}
                    $val="$($prop.Value)"
                    $match=$Global:CheatKeywords|Where-Object{$val -like "*$_*" -or $prop.Name -like "*$_*"}|Select-Object -First 1
                    if($match){
                        $results+=[PSCustomObject]@{Tipo="DEFENDER_EXCL";Nombre=$prop.Name;Ruta=$val;Tamano="";Match=$match}
