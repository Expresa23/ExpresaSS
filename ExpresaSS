function Write-Log {
    param([string]$Message, [string]$Color = "White")
    if ($Global:ModoSigiloso) {
        if ($Global:LogFile) {
            "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $Message" | Out-File -FilePath $Global:LogFile -Encoding UTF8 -Append
        }
    } else {
        Write-Host "  $Message" -ForegroundColor $Color
    }
}

