        if($match){
            $results+=[PSCustomObject]@{Tipo="CONFIG_JSON";Nombre=$jc.Name;Ruta=$jc.FullName;Tamano="";Match=$match}
        }
    }
    return $results
}

function Scan-Registry {
    $results=@()
    Write-Evidence "[CAPA4] Escaneando registro, servicios, tareas..."
    $runPaths=@(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\SOFTWARE\Wow6432Node\Microsoft\Windows\CurrentVersion\Run",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunServices",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunServicesOnce",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunServices",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunServicesOnce",
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer\Run",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer\Run",
        "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Shell Folders",
        "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\User Shell Folders"
    )
    foreach($rp in $runPaths){
        if(Test-Path $rp){
            $items=Get-ItemProperty -Path $rp -ErrorAction SilentlyContinue
            foreach($item in $items.PSObject.Properties){
                if($item.Name -match "PSPath|PSParentPath|PSChildName|PSDrive|PSProvider"){continue}
                if($item.Value -and "$($item.Value)" -match $Global:KeywordRegex){
                    $results+=[PSCustomObject]@{Tipo="REGISTRO_RUN";Ruta="$rp\$($item.Name)";Valor="$($item.Value)"}
                    Write-Evidence "[CAPA4] REG: $rp\$($item.Name)"
                }
            }
        }
    }
    $appInitPath="HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Windows"
    if(Test-Path $appInitPath){
        $appInit=Get-ItemProperty -Path $appInitPath -Name "AppInit_DLLs" -ErrorAction SilentlyContinue
        if($appInit -and $appInit.AppInit_DLLs -and $appInit.AppInit_DLLs -ne ""){
            $results+=[PSCustomObject]@{Tipo="APPINIT_DLL";Ruta=$appInitPath;Valor=$appInit.AppInit_DLLs}
            Write-Evidence "[CAPA4] APPINIT_DLL: $($appInit.AppInit_DLLs)"
        }
    }
    $ifeoPath="HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options"
    if(Test-Path $ifeoPath){
        $ifeoKeys=Get-ChildItem -Path $ifeoPath -ErrorAction SilentlyContinue
        foreach($ik in $ifeoKeys){
            $debugger=Get-ItemProperty -Path $ik.PSPath -Name "Debugger" -ErrorAction SilentlyContinue
            if($debugger -and $debugger.Debugger){
                $dk=$ik.PSChildName.ToLower()
                $match=$Global:CheatKeywords|Where-Object{$dk -like "*$_*"}|Select-Object -First 1
                if($match){
                    $results+=[PSCustomObject]@{Tipo="IFEO_HIJACK";Ruta=$ik.PSPath;Valor="Debugger: $($debugger.Debugger)";Match=$match}
                    Write-Evidence "[CAPA4] IFEO_HIJACK: $($ik.PSChildName) -> $($debugger.Debugger)"
                }
            }
            $silentExit=Get-ItemProperty -Path $ik.PSPath -Name "GlobalFlag" -ErrorAction SilentlyContinue
            if($silentExit -and $silentExit.GlobalFlag -band 0x200){
                $results+=[PSCustomObject]@{Tipo="IFEO_SILENT_EXIT";Ruta=$ik.PSPath;Valor="GlobalFlag: $($silentExit.GlobalFlag) (Silent Process Exit)"}
                Write-Evidence "[CAPA4] IFEO_SILENT_EXIT: $($ik.PSChildName)"
            }
        }
    }
    $knownDLLsPath="HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\KnownDLLs"
    if(Test-Path $knownDLLsPath){
        $knownDLLs=Get-ItemProperty -Path $knownDLLsPath -ErrorAction SilentlyContinue
        foreach($prop in $knownDLLs.PSObject.Properties){
            if($prop.Name -match "PSPath|PS"){continue}
            if($prop.Value -and "$($prop.Value)" -match $Global:KeywordRegex){
                $results+=[PSCustomObject]@{Tipo="KNOWN_DLL_MOD";Ruta=$knownDLLsPath;Valor="$($prop.Name) = $($prop.Value)"}
                Write-Evidence "[CAPA4] KNOWN_DLL_MOD: $($prop.Name) = $($prop.Value)"
            }
        }
    }
    $winlogonNotify="HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon\Notify"
    if(Test-Path $winlogonNotify){
        $notifyKeys=Get-ChildItem -Path $winlogonNotify -ErrorAction SilentlyContinue
        foreach($nk in $notifyKeys){
            $dll=Get-ItemProperty -Path $nk.PSPath -Name "DLLName" -ErrorAction SilentlyContinue
            if($dll -and $dll.DLLName){
                $match=$Global:CheatKeywords|Where-Object{$dll.DLLName -like "*$_*"}|Select-Object -First 1
                if($match){
                    $results+=[PSCustomObject]@{Tipo="WINLOGON_NOTIFY";Ruta=$nk.PSPath;Valor=$dll.DLLName;Match=$match}
                    Write-Evidence "[CAPA4] WINLOGON_NOTIFY: $($dll.DLLName)"
                }
            }
        }
    }
    try{
        $services=Get-CimInstance Win32_Service -ErrorAction SilentlyContinue
        foreach($s in $services){
            if($s.PathName -match $Global:KeywordRegex -or $s.Name -match $Global:KeywordRegex){
                $results+=[PSCustomObject]@{Tipo="SERVICIO";Nombre=$s.Name;Ruta=$s.PathName;Estado=$s.State}
                Write-Evidence "[CAPA4] SERVICIO: $($s.Name)"
            }
        }
    }catch{}
    try{
        $tasks=Get-ScheduledTask -ErrorAction SilentlyContinue
        foreach($t in $tasks){
            $actions="$($t.Actions)"
            if($actions -match $Global:KeywordRegex){
                $results+=[PSCustomObject]@{Tipo="TAREA";Nombre=$t.TaskName;Accion=$actions}
                Write-Evidence "[CAPA4] TAREA: $($t.TaskName)"
            }
        }
    }catch{}
    $autorunsPath=Join-Path $Global:TempToolsPath "autoruns.exe"
    if(Test-Path $autorunsPath){
        try{
            $arOutput=& $autorunsPath /s "$env:TEMP\_ac_autoruns. CSV" /accepteula 2>&1
            $arCsv=Get-Content "$env:TEMP\_ac_autoruns.CSV" -ErrorAction SilentlyContinue|ConvertFrom-Csv -ErrorAction SilentlyContinue
            foreach($ar in $arCsv){
                $val="$($ar.'Entry') $($ar.'Value') $($ar.'Description')".ToLower()
                $match=$Global:CheatKeywords|Where-Object{$val -like "*$_*"}|Select-Object -First 1
                if($match){
                    $results+=[PSCustomObject]@{Tipo="AUTORUNS";Nombre=$ar.'Entry';Ruta=$ar.'Value';Tamano="";Match=$match}
                    Write-Evidence "[CAPA4] AUTORUNS: $($ar.'Entry') match:$match"
                }
            }
        }catch{}
    }
    return $results
}

