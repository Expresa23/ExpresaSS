function Scan-Processes {
    $results=@()
    Write-Evidence "[CAPA1] Escaneando procesos..."
    $allProcs=Get-Process -ErrorAction SilentlyContinue
    $wmiProcs=@()
    try{$wmiProcs=Get-CimInstance Win32_Process -ErrorAction SilentlyContinue}catch{}
    $combined=@{}
    foreach($p in $allProcs){$combined[$p.Id]=$p}
    foreach($p in $wmiProcs){
        if(-not $combined.ContainsKey($p.ProcessId)){
            $fake=New-Object PSObject -Property @{Id=$p.ProcessId;ProcessName=$p.Name;StartTime=$p.CreationDate}
            $combined[$p.ProcessId]=$fake
            Write-Evidence "[!] Proceso OCULTO via WMI: $($p.Name) PID:$($p.ProcessId)"
        }
    }
    $allKeywords=$Global:CheatKeywords+$Global:InjectionClients+$Global:JarClients
    foreach($proc in $combined.Values){
        $name=$proc.ProcessName.ToLower()
        $match=$allKeywords|Where-Object{$name -like "*$_*" -or $name -eq $_}|Select-Object -First 1
        if($match){
            $path="";$startTime=""
            try{$path=$proc.Path}catch{try{$path=$proc.MainModule.FileName}catch{}}
            try{$startTime=$proc.StartTime}catch{}
            $results+=[PSCustomObject]@{Tipo="PROCESO";Nombre=$proc.ProcessName;PID=$proc.Id;Ruta=$path;Inicio=$startTime;Match=$match}
            Write-Evidence "[CAPA1] PROCESO: $($proc.ProcessName) PID:$($proc.Id) match:$match"
        }
    }
    $injectorNames=@("injector","loader","patcher","clientloader","anticheat")
    foreach($proc in $combined.Values){
        $name=$proc.ProcessName.ToLower()
        $match=$injectorNames|Where-Object{$name -like "*$_*"}|Select-Object -First 1
        if($match){
            $path=""
            try{$path=$proc.Path}catch{try{$path=$proc.MainModule.FileName}catch{}}
            $results+=[PSCustomObject]@{Tipo="INYECTOR";Nombre=$proc.ProcessName;PID=$proc.Id;Ruta=$path;Inicio=$proc.StartTime;Match=$match}
            Write-Evidence "[CAPA1] INYECTOR: $($proc.ProcessName) PID:$($proc.Id)"
        }
    }
    $javaProcs=@("javaw","java","minecraft")
    foreach($jn in $javaProcs){
        $procs=Get-Process -Name $jn -ErrorAction SilentlyContinue
        foreach($p in $procs){
            try{
                $parent=(Get-CimInstance Win32_Process -Filter "ProcessId=$($p.Id)" -ErrorAction SilentlyContinue).ParentProcessId
                $parentProc=Get-Process -Id $parent -ErrorAction SilentlyContinue
                if($parentProc -and $parentProc.ProcessName -notmatch "cmd|powershell|explorer|cmd|taskmgr|system"){
                    $parentPath=""
                    try{$parentPath=$parentProc.Path}catch{}
                    $results+=[PSCustomObject]@{Tipo="PADRE SOSPECHOSO";Nombre=$parentProc.ProcessName;PID=$parent;Ruta=$parentPath;Match="javaw parent: $($p.ProcessName) PID:$($p.Id)"}
                    Write-Evidence "[CAPA1] PADRE SOSPECHOSO: $($parentProc.ProcessName) PID:$parent lanzo $($p.ProcessName)"
                }
            }catch{}
        }
    }
    return $results
}

function Scan-Memory {
    $results=@()
    Write-Evidence "[CAPA2] Escaneando DLLs en memoria..."
    $targetNames=@("javaw","java","minecraft","chrome","firefox","msedge","opera","brave")
    foreach($target in $targetNames){
        $procs=Get-Process -Name $target -ErrorAction SilentlyContinue
        foreach($p in $procs){
            try{
                $mods=$p.Modules|Where-Object{
                    $mn=$_.ModuleName.ToLower()
                    ($Global:SuspDlls|Where-Object{$mn -like "*$_*"}) -ne $null
                }
                foreach($mod in $mods){
                    $results+=[PSCustomObject]@{Tipo="DLL_INYECTADA";Proceso=$p.ProcessName;PID=$p.Id;DLL=$mod.ModuleName;Ruta=$mod.FileName}
                    Write-Evidence "[CAPA2] DLL: $($mod.ModuleName) en $($p.ProcessName) PID:$($p.Id)"
                }
            }catch{}
            try{
                $nonStdMods=$p.Modules|Where-Object{
                    $fn=$_.FileName.ToLower()
                    ($fn -match "\\users\\.*\\appdata" -or $fn -match "\\temp\\" -or $fn -match "\\downloads\\" -or $fn -match "\\desktop\\")
                }
                foreach($mod in $nonStdMods){
                    $results+=[PSCustomObject]@{Tipo="DLL_NO_ESTANDAR";Proceso=$p.ProcessName;PID=$p.Id;DLL=$mod.ModuleName;Ruta=$mod.FileName}
                    Write-Evidence "[CAPA2] DLL_NO_ESTANDAR: $($mod.FileName) en $($p.ProcessName)"
                }
            }catch{}
        }
    }
    $stringsPath=Join-Path $Global:TempToolsPath "strings.exe"
    if(Test-Path $stringsPath){
        $javaProcs=Get-Process -Name "javaw","java" -ErrorAction SilentlyContinue
        foreach($p in $javaProcs){
            try{
                $procPath=$p.MainModule.FileName
                if($procPath){
                    $strOut=& $stringsPath -n 5 $procPath 2>&1|Select-String -Pattern $Global:KeywordRegex -SimpleMatch|Select-Object -First 10
                    foreach($s in $strOut){
                        $results+=[PSCustomObject]@{Tipo="STRING_CHEAT";Proceso=$p.ProcessName;PID=$p.Id;DLL="N/A";Ruta=$s.Line}
                        Write-Evidence "[CAPA2] STRING_CHEAT: $($s.Line) en $($p.ProcessName)"
                    }
                }
            }catch{}
        }
    }
    return $results
}

