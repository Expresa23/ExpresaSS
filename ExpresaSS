        foreach($c in $configs){
            $match=$Global:CheatFolders|Where-Object{$c.Name.ToLower() -match $_}|Select-Object -First 1
            if($match){
                $results+=[PSCustomObject]@{Tipo="CONFIG_CHEAT";Nombre=$c.Name;Ruta=$c.FullName;Tamano="";Match=$match}
                Write-Evidence "[CAPA3] CONFIG_CHEAT: $($c.FullName)"
            }
        }
    }
    $optionsPath="$mcBase\options.txt"
    if(Test-Path $optionsPath){
        try{
            $opts=Get-Content $optionsPath -ErrorAction SilentlyContinue
            $suspKeys=$opts|Where-Object{$_ -match "key\s*=\s*(?!None|UNKNOWN)" -and $_ -match "key"}|Select-Object -First 20
            if($suspKeys.Count -gt 15){
                $results+=[PSCustomObject]@{Tipo="OPTIONS_SOSPECHOSO";Nombre="options.txt";Ruta=$optionsPath;Tamano="";Match="Muchas keybinds ($($suspKeys.Count))"}
                Write-Evidence "[CAPA3] OPTIONS_SOSPECHOSO: Muchas keybinds: $($suspKeys.Count)"
            }
