            Show-Banner
            Write-Host "  [NTFS FORENSIC (MFT, USN, ADS)]" -ForegroundColor Cyan
            $results=Scan-NTFSForensic
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "9"{
            Show-Banner
            Write-Host "  [NETWORK FORENSICS]" -ForegroundColor Yellow
            $results=Scan-Network
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "10"{
            Show-Banner
            Write-Host "  [BROWSER FORENSICS]" -ForegroundColor White
            $results=Scan-BrowserForensics
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "11"{
            Show-Banner
            Write-Host "  [WINDOWS DEFENDER]" -ForegroundColor Yellow
            $results=Scan-Defender
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "12"{
            Show-Banner
            Write-Host "  [USB + REMOVABLE MEDIA]" -ForegroundColor White
            $results=Scan-USB
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "13"{
            Show-Banner
            Write-Host "  [JUMPLIST + RECENT + SHELLBAGS]" -ForegroundColor White
            $results=Scan-JumpListRecent
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "14"{
            Show-Banner
            Write-Host "  [ANTI-BYPASS (DLL hijack, fileless, VM, stego)]" -ForegroundColor Magenta
            $results=Scan-AntiBypass
            Show-Results $results
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "15"{
            $Global:ModoSigiloso=!$Global:ModoSigiloso
            Show-Banner
            if($Global:ModoSigiloso){
                Write-Host "  [MODO SIGILOSO ACTIVADO]" -ForegroundColor DarkGray
                Write-Host "  Output reducido, evidencias ocultas." -ForegroundColor DarkGray
                $Global:LogFile="$env:USERPROFILE\AppData\Local\Temp\_ac_evidence_$(Get-Date -Format 'yyyyMMdd_HHmmss').log"
                Write-Host "  Log en: $($Global:LogFile)" -ForegroundColor DarkGray
                if(-not (Test-Path $Global:LogFile)){" "|Out-File $Global:LogFile -Encoding UTF8}
                attrib +h $Global:LogFile
            }else{
                Write-Host "  [MODO SIGILOSO DESACTIVADO]" -ForegroundColor White
                $Global:LogFile=$null
            }
            Backup-Script
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "16"{
            Show-Banner
            Write-Host "  [DUMP COMPLETO]" -ForegroundColor Red
            $allResults=Invoke-AllLayers
            Show-Results $allResults
            Write-ForensicReport $allResults
            if($Global:ModoSigiloso){Write-Host "  Backup sigiloso creado." -ForegroundColor DarkGray}
            Write-Host ""
            Write-Host "  Backup de script..." -ForegroundColor Yellow
            Backup-Script
            Write-Host "  Verificando integridad..." -ForegroundColor Yellow
            Invoke-SelfCheckLoop
            Write-Host ""
            Write-Host "  DUMP COMPLETO FINALIZADO." -ForegroundColor Green
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "17"{
            Show-Banner
            Write-Host "  [GENERANDO REPORTE FORENSE COMPLETO]" -ForegroundColor Green
            $allResults=Invoke-AllLayers
            Show-Results $allResults
            Write-ForensicReport $allResults
            Write-Host "  Presiona Enter para continuar..." -ForegroundColor DarkGray
            $null=Read-Host
        }
        "18"{
            Write-Host "  Saliendo..." -ForegroundColor Yellow
            $Global:MenuActive=$false
        }
        default{
            Write-Host "  Opcion invalida." -ForegroundColor Red
            Start-Sleep -Milliseconds 500
        }
    }
}
