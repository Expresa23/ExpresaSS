function Scan-Amcache {
    $results=@()
    Write-Evidence "[CAPA8] Escaneando Amcache + ShimCache + SRUM..."
    $amcachePaths=@(
        "HKLM:\SOFTWARE\Microsoft\Windows\NT\CurrentVersion\Amcache\Root",
        "HKLM:\SOFTWARE\Microsoft\Windows\NT\CurrentVersion\Amcache\Root\File"
    )
    foreach($ap in $amcachePaths){
        if(Test-Path $ap){
            $apps=Get-ChildItem -Path $ap -ErrorAction SilentlyContinue
            foreach($app in $apps){
                $props=Get-ItemProperty -Path $app.PSPath -ErrorAction SilentlyContinue
                $name=$props.PSChildName
                $lowerName=$name.ToLower()
                $match=$Global:CheatKeywords|Where-Object{$lowerName -like "*$_*"}|Select-Object -First 1
                if($match){
                    $results+=[PSCustomObject]@{Tipo="AMCACHE";Nombre=$name;Ruta="Amcache";Tamano="";Match=$match}
                    Write-Evidence "[CAPA8] AMCACHE: $name match:$match"
                }
                $path=$props.Path
                if($path -and $path -match $Global:KeywordRegex){
                    $results+=[PSCustomObject]@{Tipo="AMCACHE_RUTA";Nombre=$name;Ruta=$path;Tamano="";Match="path"}
                    Write-Evidence "[CAPA8] AMCACHE_RUTA: $name -> $path"
                }
            }
        }
    }
    $shimPath="HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\AppCompatCache"
    if(Test-Path $shimPath){
        $shimProps=Get-ItemProperty -Path $shimPath -ErrorAction SilentlyContinue
        foreach($prop in $shimProps.PSObject.Properties){
            if($prop.Name -match "PSPath|PS|AppCompatCache"){continue}
            if($prop.Value -is [byte[]]){
                $str=[System.Text.Encoding]::Unicode.GetString($prop.Value)
                $match=$Global:CheatKeywords|Where-Object{$str -like "*$_*"}|Select-Object -First 1
                if($match){
                    $results+=[PSCustomObject]@{Tipo="SHIMCACHE";Nombre=$prop.Name;Ruta="AppCompatCache";Tamano="";Match=$match}
                    Write-Evidence "[CAPA8] SHIMCACHE: $($prop.Name) match:$match"
                }
            }
        }
    }
    $srumPath="$env:SystemRoot\System32\sru\SRUDB.dat"
    if(Test-Path $srumPath){
        $sr=(Get-Item $srumPath -ErrorAction SilentlyContinue)
        if($sr -and $sr.LastWriteTime -gt (Get-Date).AddHours(-4)){
            $results+=[PSCustomObject]@{Tipo="SRUM";Nombre="SRUDB.dat";Ruta=$srumPath;Tamano="$([math]::Round($sr.Length/1MB,1)) MB";Match="Reciente"}
            Write-Evidence "[CAPA8] SRUM: Actualizado recientemente"
        }
    }
    return $results
}

function Scan-NTFSForensic {
