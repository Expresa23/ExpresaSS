function Show-ProgressBar {
    param([int]$Current,[int]$Total,[string]$LayerName)
    $pct=[math]::Round(($Current/$Total)*100)
    $filled=[math]::Round($pct/5)
    $empty=20-$filled
    $bar=("="*"$filled")+("-"*"$empty")
    Write-Host "`r  [$bar] $pct% $LayerName   " -NoNewline -ForegroundColor $(if($pct -lt 50){"Yellow"}elseif($pct -lt 80){"Cyan"}else{"Green"})
    if($Current -eq $Total){Write-Host ""}
}

