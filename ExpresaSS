Write-Host "[6/7] Buscando archivos eliminados sospechosos..." -ForegroundColor Green
$Eliminados = @()
$exesDel = cmd /c "fsutil usn readjournal c: csv | findstr /i /c:`.exe` | findstr /i /c:`"0x80000200`"" 2>$null
$dllsDel = cmd /c "fsutil usn readjournal c: csv | findstr /i /c:`.dll` | findstr /i /c:`"0x80000200`"" 2>$null
$todosDel = $exesDel + $dllsDel
foreach ($linea in $todosDel) {
    if ($linea -match "ERROR" -or $linea -eq "") { continue }
    $path = $linea.Trim()
    if (Is-Suspicious -Path $path) {
        $Eliminados += $path
    }
}
