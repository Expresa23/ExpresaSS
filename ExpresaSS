Write-Host "[5/7] Buscando tareas programadas sospechosas..." -ForegroundColor Green
$Tareas = @()
$TareasActivas = Get-ScheduledTask -ErrorAction SilentlyContinue | Where-Object { (Is-Suspicious -Path $_.TaskName) -or (Is-Suspicious -Path $_.Description) }
foreach ($tarea in $TareasActivas) {
    $Tareas += [PSCustomObject]@{
        'Nombre' = $tarea.TaskName
        'Descripcion' = $tarea.Description
        'Estado' = $tarea.State
        'Ruta' = $tarea.TaskPath
