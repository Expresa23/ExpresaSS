function Initialize-System {
    $os=[System.Environment]::OSVersion
    $Global:OSBuild=$os.Version.Build
    $Global:IsWin11=$Global:OSBuild -ge 22000
    $Global:OSVersion=if($Global:IsWin11){"Windows 11"}else{"Windows 10"}
    $Global:IsAdmin=(New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())).IsInRole([Security.Principal.WindowsBuiltinRole]::Administrator)
    try{$wslOut=wsl --list --verbose 2>&1;if($wslOut -notmatch "no installed"){$Global:HasWSL=$true;$Global:WSLDistro=($wslOut|Select-String -Pattern "Ubuntu|Debian|Kali|SUSE|Fedora|Alpine|Arch|Parrot|Manjaro"|%{$_.Matches.Value}|Select-Object -First 1)}}catch{}
    if(-not(Test-Path $Global:TempToolsPath)){New-Item -ItemType Directory -Path $Global:TempToolsPath -Force|Out-Null}
}

function Get-ExternalTool {
    param([string]$ToolName,[string]$Url)
    $toolPath=Join-Path $Global:TempToolsPath $ToolName
    if(-not(Test-Path $toolPath)){
        try{
            Invoke-WebRequest -Uri $Url -OutFile $toolPath -UseBasicParsing -TimeoutSec 15 -ErrorAction Stop
            Write-Evidence "[TOOLS] Descargado: $ToolName"
        }catch{
            Write-Evidence ("[TOOLS] Error descargando " + $ToolName + ": " + $_.Exception.Message)
            return $null
        }
    }
    return $toolPath
}

function Initialize-Tools {
    Write-Host "  [TOOLS] Verificando herramientas externas..." -ForegroundColor Yellow
    $tools=@(
        @{Name="strings.exe";Url="https://live.sysinternals.com/strings.exe"},
        @{Name="procdump.exe";Url="https://live.sysinternals.com/procdump.exe"},
        @{Name="handle.exe";Url="https://live.sysinternals.com/handle.exe"},
        @{Name="sigcheck.exe";Url="https://live.sysinternals.com/sigcheck.exe"},
        @{Name="autoruns.exe";Url="https://live.sysinternals.com/autoruns.exe"},
        @{Name="accesschk.exe";Url="https://live.sysinternals.com/accesschk.exe"}
    )
    $downloaded=0
    foreach($t in $tools){
        $path=Get-ExternalTool -ToolName $t.Name -Url $t.Url
        if($path){$downloaded++}
    }
    Write-Host "  [TOOLS] $downloaded/$($tools.Count) herramientas disponibles" -ForegroundColor $(if($downloaded -ge 4){"Green"}else{"Yellow"})
}

function Write-Evidence {
    param([string]$Data)
    $Global:Evidencias+="[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $Data"
    if($Global:ModoSigiloso -and $Global:LogFile){
        $Global:Evidencias[-1]|Out-File -FilePath $Global:LogFile -Encoding UTF8 -Append
    }
}

