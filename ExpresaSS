function Scan-Network {
    $results=@()
    Write-Evidence "[CAPA10] Escaneando red (DNS, Firewall, conexiones)..."
    try{
        $dnsCache=Get-DnsClientCache -ErrorAction SilentlyContinue
        foreach($entry in $dnsCache){
            $name=$entry.Entry.ToLower()
            $match=$Global:CheatKeywords|Where-Object{$name -like "*$_*"}|Select-Object -First 1
            if($match){
                $results+=[PSCustomObject]@{Tipo="DNS_CHEAT";Nombre=$name;Ruta=$entry.Data;Tamano="";Match=$match}
                Write-Evidence "[CAPA10] DNS_CHEAT: $name -> $($entry.Data)"
            }
            if($name -match "cheat|hack|inject|bypass|vape|wurst|meteor|liquidbounce|download.*client|pastebin|github.*cheat"){
                $results+=[PSCustomObject]@{Tipo="DNS_SUS";Nombre=$name;Ruta=$entry.Data;Tamano="";Match="DNS suspicious"}
                Write-Evidence "[CAPA10] DNS_SUS: $name"
            }
        }
    }catch{}
    try{
        $conns=Get-NetTCPConnection -ErrorAction SilentlyContinue|
            Where-Object{$_.State -eq "Established" -and $_.RemoteAddress -ne "127.0.0.1" -and $_.RemoteAddress -ne "::1"}
        foreach($conn in $conns){
            $proc=Get-Process -Id $conn.OwningProcess -ErrorAction SilentlyContinue
            if($proc){
                $pn=$proc.ProcessName.ToLower()
                $match=$Global:CheatKeywords|Where-Object{$pn -like "*$_*"}|Select-Object -First 1
                if($match){
                    $results+=[PSCustomObject]@{Tipo="NET_CHEAT";Nombre=$proc.ProcessName;PID=$proc.Id;Ruta="Remote: $($conn.RemoteAddress):$($conn.RemotePort)";Match=$match}
                    Write-Evidence "[CAPA10] NET_CHEAT: $($proc.ProcessName) -> $($conn.RemoteAddress):$($conn.RemotePort)"
                }
            }
        }
    }catch{}
    try{
        $fwRules=Get-NetFirewallRule -Direction Inbound -Enabled True -Action Allow -ErrorAction SilentlyContinue|
            Where-Object{$_.DisplayName -match $Global:KeywordRegex}
        foreach($rule in $fwRules){
            $results+=[PSCustomObject]@{Tipo="FW_RULE";Nombre=$rule.DisplayName;Ruta="Inbound Allow";Tamano="";Match="firewall"}
            Write-Evidence "[CAPA10] FW_RULE: $($rule.DisplayName)"
        }
    }catch{}
    return $results
}

