            if($r.Tamano){$line+="$($r.Tamano) "}
            if($r.Mensaje){$line+="$($r.Mensaje) "}
            $report+="$line`n"
        }
    }
    $report+=@"

╠══════════════════════════════════════════════════════════════╣
