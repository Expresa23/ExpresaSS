function Scan-ExecutionHistory {
    $results=@()
    Write-Evidence "[CAPA6] Escaneando historial de ejecucion..."
    $hace2h=(Get-Date).AddMinutes(-120)
    $keywords=$Global:KeywordRegex
    try{
        $bamPaths=@("HKLM:\SYSTEM\CurrentControlSet\Services\bam\UserSettings\","HKLM:\SYSTEM\CurrentControlSet\Services\dam\UserSettings\")
        foreach($bamRoot in $bamPaths){
            $users=Get-ChildItem -Path $bamRoot -ErrorAction SilentlyContinue|Select-Object -ExpandProperty PSChildName
            foreach($sid in $users){
                $items=Get-ItemProperty -Path "$bamRoot$sid" -ErrorAction SilentlyContinue
                $user=try{(New-Object System.Security.Principal.SecurityIdentifier($sid)).Translate([System.Security.Principal.NTAccount]).Value}catch{"Sistema"}
                foreach($item in $items.PSObject.Properties){
                    if($item.Name -match "PSPath|PSParentPath|PSChildName|PSDrive|PSProvider"){continue}
                    $key=$item.Value
                    if($key -is [byte[]] -and $key.Length -ge 8){
                        $hex=[System.BitConverter]::ToString($key[7..0]) -replace "-",""
                        try{
                            $timeUser=[DateTime]::FromFileTimeUtc([Convert]::ToInt64($hex, 16))
                            $ppath=$item.Name -replace '\\Device\\HarddiskVolume\d+\\','C:\'
                            $match=$Global:CheatKeywords|Where-Object{$ppath -like "*$_*"}|Select-Object -First 1
                            if($timeUser -gt $hace2h -or $match){
                                $results+=[PSCustomObject]@{Tipo="BAM";Hora=$timeUser;Usuario=$user;Ruta=$ppath;Match=$match}
                                Write-Evidence "[CAPA6] BAM: $ppath $timeUser"
                            }
                        }catch{}
                    }
                }
            }
        }
    }catch{}
    try{
        $pfFiles=Get-ChildItem -Path "$env:SystemRoot\Prefetch" -Filter "*.pf" -ErrorAction SilentlyContinue|
            Where-Object{$_.LastWriteTime -gt $hace2h -or $_.Name -match $keywords}
        foreach($pf in $pfFiles){
            $match=$Global:CheatKeywords|Where-Object{$pf.Name -like "*$_*"}|Select-Object -First 1
            $results+=[PSCustomObject]@{Tipo="PREFETCH";Archivo=$pf.Name;Modificado=$pf.LastWriteTime;Match=$match}
            Write-Evidence "[CAPA6] PREFETCH: $($pf.Name)"
        }
    }catch{}
    try{
        $events=Get-WinEvent -LogName 'Security' -FilterXPath "*[System[EventID=4688]]" -MaxEvents 500 -ErrorAction SilentlyContinue
        foreach($e in $events){
            if($e.TimeCreated -gt $hace2h){
                $msg=$e.Message
                if($msg -match $keywords){
                    $short=$msg.Substring(0,[Math]::Min(200,$msg.Length))
                    $results+=[PSCustomObject]@{Tipo="EVENTO_4688";Hora=$e.TimeCreated;Mensaje=$short}
                    Write-Evidence "[CAPA6] EVENTO_4688: $($e.TimeCreated)"
                }
            }
        }
    }catch{}
    try{
        $psEvents=Get-WinEvent -LogName 'Microsoft-Windows-PowerShell/Operational' -FilterXPath "*[System[EventID=4104]]" -MaxEvents 200 -ErrorAction SilentlyContinue
        foreach($e in $psEvents){
            if($e.TimeCreated -gt $hace2h){
                $msg=$e.Message
                if($msg -match $keywords -or $msg -match "-EncodedCommand|-WindowStyle Hidden|-ExecutionPolicy Bypass"){
                    $short=$msg.Substring(0,[Math]::Min(200,$msg.Length))
                    $results+=[PSCustomObject]@{Tipo="EVENTO_PS";Hora=$e.TimeCreated;Mensaje=$short}
                    Write-Evidence "[CAPA6] EVENTO_PS: $($e.TimeCreated)"
                }
            }
        }
    }catch{}
    try{
        $svcEvents=Get-WinEvent -LogName 'System' -FilterXPath "*[System[EventID=7045]]" -MaxEvents 100 -ErrorAction SilentlyContinue
        foreach($e in $svcEvents){
            if($e.TimeCreated -gt $hace2h){
                $msg=$e.Message
                if($msg -match $keywords){
                    $short=$msg.Substring(0,[Math]::Min(200,$msg.Length))
                    $results+=[PSCustomObject]@{Tipo="EVENTO_SERVICIO";Hora=$e.TimeCreated;Mensaje=$short}
                    Write-Evidence "[CAPA6] EVENTO_SERVICIO: $($e.TimeCreated)"
                }
            }
        }
    }catch{}
    $uaPath="HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\UserAssist"
    if(Test-Path $uaPath){
        $uaGuids=Get-ChildItem -Path $uaPath -ErrorAction SilentlyContinue
        foreach($guid in $uaGuids){
            $countPath="$($guid.PSPath)\Count"
            if(Test-Path $countPath){
                $entries=Get-ItemProperty -Path $countPath -ErrorAction SilentlyContinue
                foreach($entry in $entries.PSObject.Properties){
                    if($entry.Name -match "PSPath|PS"){continue}
                    try{
                        $rot13=$entry.Name.ToCharArray()|%{
                            $c=[int]$_
                            if($c -ge 65 -and $c -le 90){[char](($c-65+13)%26+65)}
                            elseif($c -ge 97 -and $c -le 122){[char](($c-97+13)%26+97)}
                            else{[char]$c}
                        }|Join-String
                        $match=$Global:CheatKeywords|Where-Object{$rot13 -like "*$_*"}|Select-Object -First 1
                        if($match){
                            $results+=[PSCustomObject]@{Tipo="USERASSIST";Nombre=$rot13;Ruta=$rot13;Tamano="";Match=$match}
                            Write-Evidence "[CAPA6] USERASSIST: $rot13 match:$match"
                        }
                    }catch{}
                }
            }
        }
    }
    $recentDocs="HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\RecentDocs"
    if(Test-Path $recentDocs){
        $rdItems=Get-ItemProperty -Path $recentDocs -ErrorAction SilentlyContinue
        foreach($prop in $rdItems.PSObject.Properties){
            if($prop.Name -match "PSPath|PS"){continue}
            if($prop.Value -and "$($prop.Value)" -match $keywords){
                $results+=[PSCustomObject]@{Tipo="RECENT_DOCS";Nombre=$prop.Name;Ruta=$prop.Value;Match="MRU"}
                Write-Evidence "[CAPA6] RECENT_DOCS: $($prop.Value)"
            }
        }
    }
    $typedPaths="HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\TypedPaths"
    if(Test-Path $typedPaths){
        $tpItems=Get-ItemProperty -Path $typedPaths -ErrorAction SilentlyContinue
        foreach($prop in $tpItems.PSObject.Properties){
            if($prop.Name -match "PSPath|PS"){continue}
            if($prop.Value -and "$($prop.Value)" -match $keywords){
                $results+=[PSCustomObject]@{Tipo="TYPED_PATH";Nombre=$prop.Name;Ruta="$($prop.Value)";Match="typed"}
                Write-Evidence "[CAPA6] TYPED_PATH: $($prop.Value)"
            }
        }
    }
    return $results
}

