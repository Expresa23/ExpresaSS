function Scan-AntiBypass {
    $results=@()
    Write-Evidence "[CAPA15] Escaneando anti-bypass..."
    $dllHijackPaths=@(
        "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\KnownDLLs",
        "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Windows\AppInit_DLLs",
        "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon\Notify",
        "HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Image File Execution Options"
    )
    foreach($dhp in $dllHijackPaths){
        if(Test-Path $dhp){
            $items=Get-ChildItem -Path $dhp -Recurse -ErrorAction SilentlyContinue
            foreach($item in $items){
                try{
                    $props=Get-ItemProperty -Path $item.PSPath -ErrorAction SilentlyContinue
                    foreach($prop in $props.PSObject.Properties){
                        if($prop.Name -match "PSPath|PS"){continue}
                        $val="$($prop.Value)"
                        if($val -match "\.dll" -and $val -notmatch "System32|SysWOW64|Windows"){
                            $match=$Global:CheatKeywords|Where-Object{$val -like "*$_*"}|Select-Object -First 1
                            $results+=[PSCustomObject]@{Tipo="DLL_HIJACK";Nombre=$prop.Name;Ruta=$val;Tamano="";Match=$(if($match){$match}else{"Non-standard path"})}
                            Write-Evidence "[CAPA15] DLL_HIJACK: $val"
                        }
                    }
                }catch{}
            }
        }
    }
    try{
        $psProcesses=Get-CimInstance Win32_Process -Filter "Name='powershell.exe' OR Name='pwsh.exe'" -ErrorAction SilentlyContinue
        foreach($proc in $psProcesses){
            if($proc.CommandLine -match '-WindowStyle\s+Hidden|-ExecutionPolicy\s+Bypass|-EncodedCommand|-E\s+|-W\s+Hidden|-EP\s+Bypass'){
                $results+=[PSCustomObject]@{Tipo="PS_HIDDEN";PID=$proc.ProcessId;Ruta=$proc.CommandLine.Substring(0,[Math]::Min(150,$proc.CommandLine.Length));Tamano="";Match="encoded/hidden"}
                Write-Evidence "[CAPA15] PS_HIDDEN PID:$($proc.ProcessId)"
            }
        }
    }catch{}
    $vmIndicators=@("vmware","virtualbox","vbox","hyper-v","qemu","xen","sandboxie","vmtools","vm3dservice","vmusr","vmwaretray","vmwareuser","vboxservice","vboxtray")
    $procs=Get-Process -ErrorAction SilentlyContinue
    foreach($p in $procs){
        $pn=$p.ProcessName.ToLower()
        $vmMatch=$vmIndicators|Where-Object{$pn -like "*$_*"}|Select-Object -First 1
        if($vmMatch){
            $results+=[PSCustomObject]@{Tipo="VM_DETECT";Nombre=$p.ProcessName;PID=$p.Id;Ruta="";Tamano="";Match=$vmMatch}
            Write-Evidence "[CAPA15] VM_DETECT: $($p.ProcessName) ($vmMatch)"
        }
    }
    try{
        $vmWmi=Get-CimInstance Win32_ComputerSystem -ErrorAction SilentlyContinue
        if($vmWmi.Manufacturer -match "VMware|VirtualBox|QEMU|Xen|Microsoft Corporation"){
            $results+=[PSCustomObject]@{Tipo="VM_WMI";Nombre=$vmWmi.Manufacturer;Ruta=$vmWmi.Model;Tamano="";Match="VM detected"}
            Write-Evidence "[CAPA15] VM_WMI: $($vmWmi.Manufacturer) $($vmWmi.Model)"
        }
    }catch{}
    try{
        $bitlocker=Manage-Bde -Status C: 2>&1|Out-String
        if($bitlocker -match "Protection Status: Protection On"){
            $results+=[PSCustomObject]@{Tipo="BITLOCKER";Nombre="C:";Ruta="BitLocker";Tamano="";Match="Encrypted"}
            Write-Evidence "[CAPA15] BITLOCKER: C: encrypted"
        }
    }catch{}
    $prefetchDir="$env:SystemRoot\Prefetch"
    $bamPath="HKLM:\SYSTEM\CurrentControlSet\Services\bam\UserSettings"
    $recentDir="$env:USERPROFILE\AppData\Roaming\Microsoft\Windows\Recent"
    $pfCount=0;$bamCount=0;$recentCount=0
    try{$pfCount=(Get-ChildItem -Path $prefetchDir -Filter "*.pf" -ErrorAction SilentlyContinue).Count}catch{}
    try{
        if(Test-Path $bamPath){
            $bamUsers=Get-ChildItem -Path $bamPath -ErrorAction SilentlyContinue
            foreach($bu in $bamUsers){
                $items=Get-ItemProperty -Path "$bamPath\$($bu.PSChildName)" -ErrorAction SilentlyContinue
                $bamCount+=$items.PSObject.Properties|Where-Object{$_.Name -notmatch "PSPath|PS"}|Measure-Object|Select-Object -ExpandProperty Count
            }
        }
    }catch{}
    try{$recentCount=(Get-ChildItem -Path $recentDir -Filter "*.lnk" -ErrorAction SilentlyContinue).Count}catch{}
    $totalArtifacts=$pfCount+$bamCount+$recentCount
    if($totalArtifacts -lt 10){
        $results+=[PSCustomObject]@{Tipo="CLEAN_SIGNAL";Nombre="LowArtifacts";Ruta="Prefetch+BAM+Recent";Tamano="";Match="Possible cleanup ($totalArtifacts total)"}
        Write-Evidence "[CAPA15] CLEAN_SIGNAL: Only $totalArtifacts artifacts found"
    }
    $susExtensions=@(".jpg.exe",".png.exe",".pdf.exe",".doc.exe",".mp3.exe",".mp4.exe",".txt.exe",".bat.exe",".cmd.exe",".scr.exe",".com.exe",".pif.exe")
    $dlPaths=@("$env:USERPROFILE\Downloads","$env:USERPROFILE\Desktop","$env:USERPROFILE\Documents")
    foreach($dp in $dlPaths){
        if(Test-Path $dp){
            $files=Get-ChildItem -Path $dp -Recurse -Force -ErrorAction SilentlyContinue|
                Where-Object{$_.Name -match "\.(jpg|png|pdf|doc|mp3|mp4|txt|bat|cmd|scr|com|pif)\.exe$"}
            foreach($f in $files){
                $results+=[PSCustomObject]@{Tipo="DOUBLE_EXT";Nombre=$f.Name;Ruta=$f.FullName;Tamano="$([math]::Round($f.Length/1KB,1)) KB";Match="Double extension"}
                Write-Evidence "[CAPA15] DOUBLE_EXT: $($f.FullName)"
            }
        }
    }
    return $results
}

function Get-AntiForensicMarkers {
    $results=@()
    try{
        $eventsLogClear=Get-WinEvent -LogName "System" -FilterXPath "*[System[EventID=1102 or EventID=1104 or EventID=104]]" -MaxEvents 50 -ErrorAction SilentlyContinue|
            Where-Object{$_.TimeCreated -gt ((Get-Date).AddHours(-4))}
        foreach($e in $eventsLogClear){
            $results+=[PSCustomObject]@{Tipo="LOG_CLEAR";Hora=$e.TimeCreated;EventID=$e.Id}
            Write-Evidence "[ANTIFORENSE] Log limpiado EventID:$($e.Id) $($e.TimeCreated)"
        }
    }catch{}
    try{
        $secClear=Get-WinEvent -LogName "Security" -FilterXPath "*[System[EventID=1102]]" -MaxEvents 20 -ErrorAction SilentlyContinue|
            Where-Object{$_.TimeCreated -gt ((Get-Date).AddHours(-4))}
        foreach($e in $secClear){
            $results+=[PSCustomObject]@{Tipo="SEC_CLEAR";Hora=$e.TimeCreated;EventID=$e.Id}
            Write-Evidence "[ANTIFORENSE] Security log limpiado: $($e.TimeCreated)"
        }
    }catch{}
    return $results
}

function Test-ScriptIntegrity {
    if(-not $Global:ScriptHashBase -or $Global:ScriptHashBase -eq "NO_DISPONIBLE"){return $false}
    try{
        $currentHash=(Get-FileHash -Path $PSCommandPath -Algorithm SHA256 -ErrorAction SilentlyContinue).Hash
        if($currentHash -ne $Global:ScriptHashBase){
            Write-Evidence "[!] INTEGRIDAD COMPROMETIDA - hash cambio!"
            if($Global:ModoSigiloso){
                $evidencia="Script comprometido en $env:COMPUTERNAME`nHash original: $($Global:ScriptHashBase)`nHash actual: $currentHash`nFecha: $(Get-Date)"
                try{Write-EventLog -LogName "Application" -Source "AC-BQGE" -EntryType Warning -EventId 9999 -Message $evidencia}catch{}
                try{$evidencia|Out-File -FilePath "$env:USERPROFILE\AppData\Local\Temp\_ac_evidencia_$(Get-Date -Format 'yyyyMMddHHmmss').txt" -Encoding UTF8}catch{}
            }
            return $false
        }
        return $true
    }catch{return $false}
}

