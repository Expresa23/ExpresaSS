Write-Host "[4/7] Buscando servicios sospechosos..." -ForegroundColor Green
$Servicios = @()
$ServiciosActivos = Get-Service | Where-Object { (Is-Suspicious -Path $_.DisplayName) -or (Is-Suspicious -Path $_.ServiceName) }
foreach ($svc in $ServiciosActivos) {
    $Servicios += [PSCustomObject]@{
        'Nombre' = $svc.ServiceName
        'DisplayName' = $svc.DisplayName
        'Estado' = $svc.Status
        'Tipo' = $svc.StartType
    }
}
$ServiciosLog = Join-Path $Folder "4_Servicios_Sospechosos.txt"
