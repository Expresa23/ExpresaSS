try {
    $Global:ScriptHashBase = (Get-FileHash -Path $PSCommandPath -Algorithm SHA256 -ErrorAction Stop).Hash
} catch { $Global:ScriptHashBase = "NO_DISPONIBLE" }

function Test-Admin {
    (New-Object Security.Principal.WindowsPrincipal([Security.Principal.WindowsIdentity]::GetCurrent())).IsInRole([Security.Principal.WindowsBuiltinRole]::Administrator)
}

function Write-Evidence {
    param([string]$Data)
    $Global:Evidencias += "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $Data"
    if ($Global:ModoSigiloso -and $Global:LogFile) {
        $Global:Evidencias[-1] | Out-File -FilePath $Global:LogFile -Encoding UTF8 -Append
    }
}

