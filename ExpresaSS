    Write-Host ""
    foreach($layer in $layers){
        $color=switch -Wildcard($layer.Name){
            "PROCESO*"{"Red"}"INYECTOR*"{"Red"}"DLL*"{"Red"}"DLL_NO*"{"Magenta"}
            "PADRE*"{"Red"}"STRING*"{"Magenta"}
            "CARPETA*"{"Red"}"MOD_SOSPECHOSO*"{"Red"}"MOD_HEURISTICO*"{"Yellow"}
            "VERSION*"{"Red"}"CONFIG*"{"Yellow"}"LOG*"{"DarkYellow"}"CRASH*"{"DarkGray"}
            "LAUNCHER*"{"Yellow"}"OPTIONS*"{"Yellow"}"USERCACHE*"{"DarkGray"}
            "REGISTRO*"{"Yellow"}"APPINIT*"{"Red"}"IFEO*"{"Red"}
            "KNOWN*"{"Red"}"WINLOGON*"{"Red"}"SERVICIO*"{"Red"}
            "TAREA*"{"Yellow"}"AUTORUNS*"{"Yellow"}
            "DRIVER*"{"Red"}"HOOK*"{"Magenta"}
            "BAM*"{"Gray"}"PREFETCH*"{"Gray"}"EVENTO*"{"DarkGray"}
            "USERASSIST*"{"Cyan"}"RECENT*"{"DarkGray"}"TYPED*"{"DarkGray"}
            "PAPELERA*"{"DarkYellow"}"TEMP*"{"DarkYellow"}"RECENT_EXE*"{"Red"}
            "AMCACHE*"{"Cyan"}"SHIM*"{"Cyan"}"SRUM*"{"Gray"}
            "ADS*"{"Magenta"}"USN*"{"Cyan"}"MFT*"{"Cyan"}
            "DNS*"{"Yellow"}"NET*"{"Yellow"}"FW*"{"Yellow"}
            "BROWSER*"{"White"}
            "DEFENDER*"{"Yellow"}
            "USB*"{"White"}"MOUNT*"{"White"}"SETUPAPI*"{"Gray"}
            "JUMPLIST*"{"DarkGray"}"SHELLBAG*"{"Gray"}
            "DLL_HIJACK*"{"Red"}"PS_HIDDEN*"{"Red"}
            "VM*"{"Magenta"}"BITLOCKER*"{"Magenta"}
            "DOUBLE*"{"Red"}"CLEAN*"{"Red"}
            "LOG_CLEAR*"{"Red"}"SEC_CLEAR*"{"Red"}
            default{"White"}
        }
        Write-Host "  [$($layer.Name)] $($layer.Count)" -ForegroundColor $color
    }
    Write-Host ""
    Write-Host "  ─────────────────────────────────────────" -ForegroundColor DarkGray
    $i=1
    foreach($r in $results){
        Write-Host "  $i. " -NoNewline -ForegroundColor DarkGray
        Write-Host "[$($r.Tipo)] " -NoNewline -ForegroundColor Cyan
        if($r.Nombre){Write-Host "$($r.Nombre) " -NoNewline -ForegroundColor White}
        if($r.PID){Write-Host "PID:$($r.PID) " -NoNewline -ForegroundColor Gray}
        if($r.Proceso){Write-Host "$($r.Proceso) " -NoNewline -ForegroundColor White}
        if($r.DLL){Write-Host "$($r.DLL) " -NoNewline -ForegroundColor Red}
        if($r.Ruta){Write-Host "$($r.Ruta) " -NoNewline -ForegroundColor DarkGray}
        if($r.Valor){Write-Host "$($r.Valor) " -NoNewline -ForegroundColor Yellow}
        if($r.Match){Write-Host "[$($r.Match)]" -NoNewline -ForegroundColor Red}
        if($r.Hora){Write-Host "$($r.Hora) " -NoNewline -ForegroundColor DarkGray}
        if($r.Usuario){Write-Host "U:$($r.Usuario) " -NoNewline -ForegroundColor DarkGray}
        if($r.Estado){Write-Host "E:$($r.Estado) " -NoNewline -ForegroundColor Gray}
        if($r.Accion){Write-Host "A:$($r.Accion) " -NoNewline -ForegroundColor Yellow}
        if($r.Tamano){Write-Host "$($r.Tamano) " -NoNewline -ForegroundColor DarkGray}
        if($r.Mensaje){Write-Host "$($r.Mensaje) " -NoNewline}
        Write-Host ""
        $i++
    }
}

